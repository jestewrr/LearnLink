@{
    ViewData["Title"] = "Best Practices & Recommendations";
    ViewData["ActivePage"] = "BestPractices";

    var recommendations = ViewBag.Recommendations as List<LearnLink.Models.ResourceViewModel> ?? new List<LearnLink.Models.ResourceViewModel>();
    var trending = ViewBag.Trending as List<LearnLink.Models.ResourceViewModel> ?? new List<LearnLink.Models.ResourceViewModel>();
    var continueReading = ViewBag.ContinueReading as List<LearnLink.Models.ReadingHistoryViewModel> ?? new List<LearnLink.Models.ReadingHistoryViewModel>();
    var subjects = ViewBag.LearningProgress as IEnumerable<dynamic> ?? new List<dynamic>();
    var totalProgress = (int)(ViewBag.TotalProgress ?? 0);

    string GetGradient(string format) => format?.ToUpper() switch
    {
        "PDF" => "background: linear-gradient(135deg, #ef4444, #dc2626)",
        "DOCX" => "background: linear-gradient(135deg, #3b82f6, #2563eb)",
        "PPTX" => "background: linear-gradient(135deg, #f59e0b, #d97706)",
        "XLSX" => "background: linear-gradient(135deg, #10b981, #059669)",
        _ => "background: linear-gradient(135deg, #8b5cf6, #7c3aed)"
    };

    string GetIcon(string format) => format?.ToUpper() switch
    {
        "PDF" => "bi-file-earmark-pdf",
        "DOCX" => "bi-file-earmark-word",
        "PPTX" => "bi-file-earmark-ppt",
        "XLSX" => "bi-file-earmark-excel",
        _ => "bi-file-earmark"
    };
}

<div class="ll-best-practices">
    <!-- Page Header -->
    <div class="ll-page-header">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h1 class="ll-page-title">Best Practices & Recommendations</h1>
                <div class="ll-breadcrumb">
                    <a href="@Url.Action("Dashboard", "Home")">Home</a>
                    <i class="bi bi-chevron-right small"></i>
                    <span>Best Practices</span>
                </div>
            </div>
        </div>
    </div>

    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
    {
        var contentGaps = ViewBag.ContentGaps as IEnumerable<dynamic>;
        var qualityNeeds = ViewBag.QualityNeeds as IEnumerable<dynamic>;
        var topContributors = ViewBag.TopContributors as IEnumerable<dynamic>;
        
        <!-- Admin Dashboard Banner -->
        <div class="ll-card mb-4" style="background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%); border: none;">
            <div class="ll-card-body py-4">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h4 class="fw-bold mb-2"><i class="bi bi-activity me-2"></i>System Health & Content Gaps</h4>
                        <p class="mb-0 text-dark opacity-75">Review system-wide performance and identify areas where more resources are needed to support students.</p>
                    </div>
                    <div class="col-lg-4 text-end d-none d-lg-block">
                        <i class="bi bi-graph-up-arrow" style="font-size: 4rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <!-- Content Gaps -->
                <div class="ll-card mb-4 h-100">
                    <div class="ll-card-header">
                        <h5 class="ll-card-title"><i class="bi bi-exclamation-triangle me-2 text-warning"></i>Content Gaps (High Demand)</h5>
                        <p class="text-muted small mb-0">Subjects with the highest views relative to available resources</p>
                    </div>
                    <div class="ll-card-body">
                        <div class="row g-3">
                            @if (contentGaps != null)
                            {
                                foreach (var stat in contentGaps)
                                {
                                    <div class="col-md-6">
                                        <div class="p-3 border rounded text-center bg-light h-100">
                                            <h6 class="fw-bold text-dark mb-1">@stat.Subject</h6>
                                            <div class="text-muted small mb-2">Demand Score: @(stat.DemandScore.ToString("0.0")) views/resource</div>
                                            <div class="ll-badge ll-badge-warning mx-auto">Needs More Content</div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4">
                 <div class="ll-card mb-4 h-100">
                    <div class="ll-card-header">
                        <h5 class="ll-card-title">Quality Needs</h5>
                        <p class="small text-muted mb-0">Subjects with lowest average ratings</p>
                    </div>
                    <div class="ll-card-body">
                        @if(qualityNeeds != null)
                        {
                            foreach(var q in qualityNeeds)
                            {
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between small mb-1">
                                        <span class="fw-bold">@q.Subject</span>
                                        <span class="text-warning fw-bold"><i class="bi bi-star-fill"></i> @q.AvgRating.ToString("0.0")</span>
                                    </div>
                                    <div class="text-muted small">@q.ResourceCount resources</div>
                                </div>
                            }
                        }
                    </div>
                 </div>
            </div>
            
            <div class="col-12">
                <!-- Top Contributors -->
                <div class="ll-card mb-4">
                    <div class="ll-card-header">
                        <h5 class="ll-card-title"><i class="bi bi-award me-2 text-success"></i>Top Contributors</h5>
                        <p class="small text-muted mb-0">Users generating the most engagement</p>
                    </div>
                    <div class="table-responsive">
                        <table class="ll-table">
                            <thead><tr><th>Contributor</th><th>Uploads</th><th>Total Views Generated</th></tr></thead>
                            <tbody>
                                @if(topContributors != null)
                                {
                                    foreach (var c in topContributors)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="ll-avatar rounded-circle text-white d-flex align-items-center justify-content-center" style="width:32px;height:32px;background:@c.User.AvatarColor;font-size:0.8rem">@c.User.Initials</div>
                                                    <span class="fw-medium">@c.User.FullName</span>
                                                </div>
                                            </td>
                                            <td>@c.TotalUploads</td>
                                            <td>@c.TotalViews.ToString("N0")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (User.IsInRole("Contributor"))
    {
        var myTopSubjects = ViewBag.MyTopSubjects as IEnumerable<dynamic>;
        var systemHotTopics = ViewBag.SystemHotTopics as IEnumerable<dynamic>;
        var myTopResources = ViewBag.MyTopResources as List<LearnLink.Models.ResourceViewModel>;
        var totalViews = (int)(ViewBag.TotalMyViews ?? 0);
        var totalDownloads = (int)(ViewBag.TotalMyDownloads ?? 0);
        
        <!-- Contributor Dashboard Banner -->
        <div class="ll-card mb-4" style="background: linear-gradient(135deg, #dcfce7 0%, #86efac 100%); border: none;">
            <div class="ll-card-body py-4">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h4 class="fw-bold mb-2"><i class="bi bi-lightbulb me-2 text-success"></i>Contributor Strategy Dashboard</h4>
                        <p class="mb-0 text-dark opacity-75">See how your resources are performing and discover high-demand topics to focus on next.</p>
                    </div>
                    <div class="col-lg-4 text-end d-none d-lg-block">
                        <i class="bi bi-bar-chart-fill" style="font-size: 4rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="ll-card h-100 ll-stat-accent-card">
                    <div class="ll-card-body d-flex align-items-center gap-4 py-4">
                        <div class="ll-tip-icon" style="width: 60px; height: 60px; border-radius: 12px; background: #dbeafe; color: #2563eb; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-eye fs-2"></i>
                        </div>
                        <div>
                            <h2 class="fw-bold mb-0">@totalViews.ToString("N0")</h2>
                            <div class="text-muted fw-medium">Total Views Generated</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="ll-card h-100 ll-stat-accent-card">
                    <div class="ll-card-body d-flex align-items-center gap-4 py-4">
                        <div class="ll-tip-icon" style="width: 60px; height: 60px; border-radius: 12px; background: #d1fae5; color: #059669; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-download fs-2"></i>
                        </div>
                        <div>
                            <h2 class="fw-bold mb-0">@totalDownloads.ToString("N0")</h2>
                            <div class="text-muted fw-medium">Total Downloads Generated</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <!-- System Needs -->
                <div class="ll-card mb-4 h-100">
                    <div class="ll-card-header d-flex justify-content-between align-items-center">
                        <h5 class="ll-card-title"><i class="bi bi-fire me-2 text-danger"></i>System Hot Topics</h5>
                        <a href="@Url.Action("Upload", "Home")" class="btn btn-sm btn-primary">Upload Resource</a>
                    </div>
                    <div class="ll-card-body">
                        <p class="text-muted small mb-3">These subjects are trending and currently in high demand. Consider uploading materials for these topics to maximize your impact!</p>
                        <div class="row g-3">
                            @if(systemHotTopics != null)
                            {
                                foreach(var stat in systemHotTopics)
                                {
                                    <div class="col-md-6">
                                        <div class="p-3 border rounded text-center bg-light">
                                            <h6 class="fw-bold text-dark mb-1">@stat.Subject</h6>
                                            <div class="ll-badge ll-badge-danger mx-auto">High Demand</div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                 <!-- My Strengths -->
                 <div class="ll-card mb-4 h-100">
                    <div class="ll-card-header">
                        <h5 class="ll-card-title">Your Top Subjects</h5>
                        <p class="small text-muted mb-0">Your most successful topics</p>
                    </div>
                    <div class="ll-card-body">
                        @if(myTopSubjects != null)
                        {
                            foreach(var s in myTopSubjects)
                            {
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between small mb-1 fw-bold">
                                        <span>@s.Subject</span>
                                        <span class="text-primary">@s.TotalViews views</span>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@s.TotalDownloads downloads</div>
                                </div>
                            }
                        }
                    </div>
                 </div>
            </div>
            
            <div class="col-12">
                <!-- My Top Resources -->
                <div class="ll-card mb-4">
                     <div class="ll-card-header">
                        <h5 class="ll-card-title">Your Most Engaging Resources</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="ll-table">
                            <thead><tr><th>Resource</th><th>Views</th><th>Downloads</th></tr></thead>
                            <tbody>
                                @if (myTopResources != null)
                                {
                                    foreach (var r in myTopResources)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi @r.IconClass" style="color:@r.IconColor;"></i> <span class="fw-medium">@r.Title</span>
                                                </div>
                                            </td>
                                            <td>@r.ViewCount</td>
                                            <td>@r.DownloadCount</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Personalized Recommendations Banner -->
        <div class="ll-card mb-4" style="background: linear-gradient(135deg, #fef3c7 0%, #fcd34d 100%); border: none;">
            <div class="ll-card-body py-4">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h4 class="fw-bold mb-2"><i class="bi bi-stars me-2"></i>Personalized Recommendations</h4>
                        <p class="mb-0 text-dark opacity-75">Based on your reading history and interests, we've curated these resources just for you.
                           Keep exploring to get more accurate recommendations!</p>
                    </div>
                    <div class="col-lg-4 text-end d-none d-lg-block">
                        <i class="bi bi-magic" style="font-size: 4rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Stats Row -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="ll-card h-100" style="border-left: 4px solid var(--ll-primary);">
                    <div class="ll-card-body py-3 text-center">
                        <div class="fs-3 fw-bold" style="color: var(--ll-primary);">@recommendations.Count</div>
                        <div class="small text-muted fw-medium">For You</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ll-card h-100" style="border-left: 4px solid var(--ll-success);">
                    <div class="ll-card-body py-3 text-center">
                        <div class="fs-3 fw-bold" style="color: var(--ll-success);">@continueReading.Count</div>
                        <div class="small text-muted fw-medium">In Progress</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ll-card h-100" style="border-left: 4px solid var(--ll-warning);">
                    <div class="ll-card-body py-3 text-center">
                        <div class="fs-3 fw-bold" style="color: var(--ll-warning);">@trending.Count</div>
                        <div class="small text-muted fw-medium">Trending</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ll-card h-100" style="border-left: 4px solid var(--ll-info);">
                    <div class="ll-card-body py-3 text-center">
                        <div class="fs-3 fw-bold" style="color: var(--ll-info);">@(totalProgress)%</div>
                        <div class="small text-muted fw-medium">Overall Progress</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <!-- For You Section -->
                <div class="ll-card mb-4">
                    <div class="ll-card-header">
                        <h5 class="ll-card-title"><i class="bi bi-person-heart me-2 text-danger"></i>Recommended for You</h5>
                        <span class="ll-badge ll-badge-info">Based on your history</span>
                    </div>
                    <div class="ll-card-body">
                        <div class="row g-3">
                            @{
                                int matchScore = 98;
                            }
                            @foreach (var resource in recommendations)
                            {
                            <div class="col-md-6">
                                <a href="@Url.Action("ResourceDetail", "Home", new { id = resource.Id })" class="text-decoration-none text-dark">
                                    <div class="d-flex gap-3 p-3 border rounded hover-shadow" style="transition: all 0.3s;">
                                        <div style="width: 56px; height: 56px; @GetGradient(resource.FileFormat); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: white; flex-shrink: 0;">
                                            <i class="bi @GetIcon(resource.FileFormat) fs-4"></i>
                                        </div>
                                        <div class="flex-fill min-w-0">
                                            <h6 class="fw-bold mb-1 text-truncate">@resource.Title</h6>
                                            <p class="small text-muted mb-2 text-truncate">@resource.Description</p>
                                            <div class="d-flex gap-2 flex-wrap">
                                                <span class="ll-tag">@resource.Subject</span>
                                                <span class="ll-badge ll-badge-success">@(matchScore)% match</span>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                                matchScore -= new Random(resource.Title.GetHashCode()).Next(3, 8);
                            }
                        </div>
                    </div>
                </div>

                <!-- Continue Reading -->
                @if (continueReading.Any())
                {
                <div class="ll-card mb-4">
                    <div class="ll-card-header">
                        <h5 class="ll-card-title"><i class="bi bi-bookmark-check me-2 text-info"></i>Continue Reading</h5>
                        <a href="@Url.Action("ReadingHistory", "Home")" class="ll-btn ll-btn-outline ll-btn-sm">View History</a>
                    </div>
                    <div class="ll-card-body">
                        <div class="row g-3">
                            @foreach (var item in continueReading.Take(4))
                            {
                            <div class="col-md-6">
                                <a href="@Url.Action("ResourceDetail", "Home", new { id = item.ResourceId })" class="text-decoration-none text-dark">
                                    <div class="d-flex gap-3 p-3 border rounded" style="transition: all 0.3s;">
                                        <div style="width: 48px; height: 48px; @GetGradient(item.FileFormat); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: white; flex-shrink: 0;">
                                            <i class="bi @GetIcon(item.FileFormat) fs-5"></i>
                                        </div>
                                        <div class="flex-fill min-w-0">
                                            <h6 class="fw-bold small mb-1 text-truncate">@item.Title</h6>
                                            <div class="small text-muted mb-2">@item.Subject · @item.Author</div>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="flex-fill ll-progress" style="height: 6px; border-radius: 3px; overflow: hidden;">
                                                    <div style="width: @(item.Progress)%; height: 100%; background: var(--ll-primary); border-radius: 3px;"></div>
                                                </div>
                                                <span class="small fw-medium" style="color: var(--ll-primary);">@(item.Progress)%</span>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                            }
                        </div>
                    </div>
                </div>
                }
            </div>

            <div class="col-lg-4">
                <!-- Learning Progress -->
                <div class="ll-card mb-4">
                    <div class="ll-card-header">
                        <h5 class="ll-card-title">Your Learning Progress</h5>
                    </div>
                    <div class="ll-card-body">
                        <div class="text-center mb-4">
                            <div style="width: 120px; height: 120px; margin: 0 auto; position: relative;">
                                <svg viewBox="0 0 36 36" style="transform: rotate(-90deg);">
                                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e2e8f0" stroke-width="3"/>
                                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#2563eb" stroke-width="3" stroke-dasharray="@totalProgress, 100"/>
                                </svg>
                                <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center;">
                                    <div class="fs-4 fw-bold">@(totalProgress)%</div>
                                    <div class="small text-muted">Complete</div>
                                </div>
                            </div>
                        </div>
                        @foreach (var item in subjects)
                        {
                            var subjectName = (string)item.Subject;
                            var pct = (int)item.Percent;
                            var color = (string)item.Color;
                            <div class="mb-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>@subjectName</span>
                                    <span class="fw-medium">@(pct)%</span>
                                </div>
                                <div class="ll-progress">
                                    <div class="ll-progress-bar @(color == "primary" || color == "success" ? color : "")" style="width: @(pct)%; @(color != "primary" && color != "success" ? $"background: {color};" : "")"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Best Practices Tips -->
                <div class="ll-card mb-4">
                    <div class="ll-card-header">
                        <h5 class="ll-card-title"><i class="bi bi-lightbulb me-2 text-warning"></i>Study Tips</h5>
                    </div>
                    <div class="ll-card-body">
                        <div class="d-flex gap-2 mb-3 pb-3 border-bottom">
                            <div class="flex-shrink-0" style="width: 36px; height: 36px; background: #dbeafe; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-clock text-primary"></i>
                            </div>
                            <div>
                                <div class="small fw-bold">Set a Schedule</div>
                                <div class="small text-muted">Read at least one resource daily to build a streak.</div>
                            </div>
                        </div>
                        <div class="d-flex gap-2 mb-3 pb-3 border-bottom">
                            <div class="flex-shrink-0" style="width: 36px; height: 36px; background: #d1fae5; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-pencil text-success"></i>
                            </div>
                            <div>
                                <div class="small fw-bold">Take Notes</div>
                                <div class="small text-muted">Submit lessons learned after each resource.</div>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <div class="flex-shrink-0" style="width: 36px; height: 36px; background: #fef3c7; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-people text-warning"></i>
                            </div>
                            <div>
                                <div class="small fw-bold">Discuss & Share</div>
                                <div class="small text-muted">Join discussions to deepen your understanding.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <!-- Trending This Week -->
                <div class="ll-card mb-4">
                    <div class="ll-card-header">
                        <h5 class="ll-card-title"><i class="bi bi-fire me-2 text-danger"></i>System Wide Trending</h5>
                        <a href="@Url.Action("Repository", "Home")" class="ll-btn ll-btn-outline ll-btn-sm">View All</a>
                    </div>
                    <div class="ll-card-body p-0">
                        <div class="table-responsive-xl">
                            <table class="ll-table">
                                <thead>
                                    <tr>
                                        <th>Rank</th>
                                        <th>Resource</th>
                                        <th>Views</th>
                                        <th>Downloads</th>
                                        <th>Rating</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        string[] medals = { "🥇", "🥈", "🥉" };
                                        string[] badgeClasses = { "bg-warning text-dark", "bg-secondary", "bg-danger" };
                                    }
                                    @for (int i = 0; i < trending.Count; i++)
                                    {
                                        var resource = trending[i];
                                    <tr>
                                        <td>
                                            @if (i < 3)
                                            {
                                            <span class="badge @badgeClasses[i]">@medals[i] @(i + 1)</span>
                                            }
                                            else
                                            {
                                            <span class="badge bg-light text-dark">@(i + 1)</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("ResourceDetail", "Home", new { id = resource.Id })" class="text-decoration-none text-dark">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi @resource.IconClass @resource.IconColor"></i>
                                                    <div>
                                                        <div class="fw-medium text-primary">@resource.Title</div>
                                                        <small class="text-muted">@resource.GradeLevel • @resource.Subject</small>
                                                    </div>
                                                </div>
                                            </a>
                                        </td>
                                        <td>@resource.ViewCount.ToString("N0")</td>
                                        <td>@resource.DownloadCount.ToString("N0")</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-1">
                                                <i class="bi bi-star-fill text-warning"></i>
                                                <span>@resource.Rating.ToString("0.0")</span>
                                            </div>
                                        </td>
                                    </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    </div>
</div>
