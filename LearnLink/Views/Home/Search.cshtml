@model LearnLink.Models.GlobalSearchViewModel

@{
    ViewData["Title"] = "Global Search";
    ViewData["ActivePage"] = "Search";

    var dashboardAction = User.IsInRole("Student") ? "StudentDashboard" : "Dashboard";
}

<div class="ll-page-header">
    <div>
        <h1 class="ll-page-title">Global Search</h1>
        <div class="ll-breadcrumb">
            <a href="@Url.Action(dashboardAction, "Home")">Dashboard</a>
            <i class="bi bi-chevron-right small"></i>
            <span>Search</span>
        </div>
    </div>
</div>

<div class="ll-card mb-4">
    <div class="ll-card-body py-4">
        <form action="@Url.Action("Search", "Home")" method="get" role="search">
            <div class="position-relative">
                <i class="bi bi-search position-absolute top-50 translate-middle-y ms-3 text-muted fs-5"></i>
                <input type="text" class="ll-form-control ps-5 py-3" name="q" value="@Model.Query" placeholder="Search resources, lessons, discussions, and users..." style="font-size: 1.1rem;" autofocus>
            </div>
        </form>

        @if (Model.HasQuery)
        {
            <div class="d-flex flex-wrap gap-2 mt-3">
                <span class="ll-tag">@Model.TotalResults total result@(Model.TotalResults == 1 ? string.Empty : "s")</span>
                <span class="ll-tag">@Model.Resources.Count resources</span>
                <span class="ll-tag">@Model.Lessons.Count lessons</span>
                <span class="ll-tag">@Model.Discussions.Count discussions</span>
                @if (Model.CanSearchUsers)
                {
                    <span class="ll-tag">@Model.Users.Count users</span>
                }
            </div>
        }
    </div>
</div>

@if (!Model.HasQuery)
{
    <div class="ll-card">
        <div class="ll-card-body text-center py-5">
            <i class="bi bi-search fs-1 text-muted mb-3 d-block"></i>
            <h4>Search the whole system</h4>
            <p class="text-muted mb-0">Use the top search to find resources, lessons learned, discussions, and @(Model.CanSearchUsers ? "users" : "content") from one place.</p>
        </div>
    </div>
}
else if (!Model.HasResults)
{
    <div class="ll-card">
        <div class="ll-card-body text-center py-5">
            <i class="bi bi-search fs-1 text-muted mb-3 d-block"></i>
            <h4>No results found</h4>
            <p class="text-muted mb-0">Try a different keyword or a broader phrase.</p>
        </div>
    </div>
}
else
{
    if (Model.Resources.Any())
    {
        <div class="ll-card mb-4">
            <div class="ll-card-header">
                <h5 class="ll-card-title">Resources</h5>
                <span class="badge bg-light text-muted border">@Model.Resources.Count</span>
            </div>
            <div class="ll-card-body">
                <div class="d-flex flex-column gap-3">
                    @foreach (var resource in Model.Resources)
                    {
                        <a href="@Url.Action("ResourceDetail", "Home", new { id = resource.Id })" class="text-decoration-none text-reset">
                            <div class="border rounded-3 p-3 h-100">
                                <div class="d-flex gap-3 align-items-start">
                                    <div style="width: 48px; height: 48px; background: @resource.IconBg; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                        <i class="bi @resource.IconClass @resource.IconColor fs-5"></i>
                                    </div>
                                    <div class="flex-fill">
                                        <div class="fw-bold mb-1">@resource.Title</div>
                                        <div class="text-muted small mb-2">@resource.Description</div>
                                        <div class="d-flex flex-wrap gap-2 mb-2">
                                            <span class="ll-tag">@resource.Subject</span>
                                            <span class="ll-tag">@resource.GradeLevel</span>
                                            <span class="ll-tag">@resource.FileFormat • @resource.FileSize</span>
                                        </div>
                                        <div class="d-flex flex-wrap gap-3 text-muted small">
                                            <span><i class="bi bi-person me-1"></i>@resource.Uploader</span>
                                            <span><i class="bi bi-eye me-1"></i>@resource.ViewCount</span>
                                            <span><i class="bi bi-download me-1"></i>@resource.DownloadCount</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    }

    if (Model.Lessons.Any())
    {
        <div class="ll-card mb-4">
            <div class="ll-card-header">
                <h5 class="ll-card-title">Lessons Learned</h5>
                <span class="badge bg-light text-muted border">@Model.Lessons.Count</span>
            </div>
            <div class="ll-card-body">
                <div class="d-flex flex-column gap-3">
                    @foreach (var lesson in Model.Lessons)
                    {
                        <a href="@Url.Action("LessonsLearned", "Home")" class="text-decoration-none text-reset">
                            <div class="border rounded-3 p-3 h-100">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-bold mb-1">@lesson.Title</div>
                                        <div class="text-muted small mb-2">@lesson.Content</div>
                                        <div class="d-flex flex-wrap gap-2 mb-2">
                                            @if (!string.IsNullOrWhiteSpace(lesson.Category))
                                            {
                                                <span class="ll-tag">@lesson.Category</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(lesson.ResourceTitle))
                                            {
                                                <span class="ll-tag">@lesson.ResourceTitle</span>
                                            }
                                        </div>
                                        <div class="text-muted small"><i class="bi bi-person me-1"></i>@lesson.Author</div>
                                    </div>
                                    <span class="small text-muted text-nowrap">@lesson.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    }

    if (Model.Discussions.Any())
    {
        <div class="ll-card mb-4">
            <div class="ll-card-header">
                <h5 class="ll-card-title">Discussions</h5>
                <span class="badge bg-light text-muted border">@Model.Discussions.Count</span>
            </div>
            <div class="ll-card-body">
                <div class="d-flex flex-column gap-3">
                    @foreach (var discussion in Model.Discussions)
                    {
                        <a href="@Url.Action("Discussions", "Home", new { id = discussion.Id })" class="text-decoration-none text-reset">
                            <div class="border rounded-3 p-3 h-100">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-bold mb-1">@discussion.Title</div>
                                        <div class="text-muted small mb-2">@discussion.Content</div>
                                        <div class="d-flex flex-wrap gap-2 mb-2">
                                            <span class="ll-tag">@discussion.Type</span>
                                            @if (!string.IsNullOrWhiteSpace(discussion.Category))
                                            {
                                                <span class="ll-tag">@discussion.Category</span>
                                            }
                                            <span class="ll-tag">@discussion.Status</span>
                                        </div>
                                        <div class="d-flex flex-wrap gap-3 text-muted small">
                                            <span><i class="bi bi-person me-1"></i>@discussion.Author</span>
                                            <span><i class="bi bi-chat-left-text me-1"></i>@discussion.ReplyCount</span>
                                            <span><i class="bi bi-eye me-1"></i>@discussion.ViewCount</span>
                                        </div>
                                    </div>
                                    <span class="small text-muted text-nowrap">@discussion.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    }

    if (Model.CanSearchUsers && Model.Users.Any())
    {
        <div class="ll-card">
            <div class="ll-card-header">
                <h5 class="ll-card-title">Users</h5>
                <span class="badge bg-light text-muted border">@Model.Users.Count</span>
            </div>
            <div class="ll-card-body">
                <div class="d-flex flex-column gap-3">
                    @foreach (var user in Model.Users)
                    {
                        <a href="@Url.Action("UserDetails", "Home", new { email = user.Email })" class="text-decoration-none text-reset">
                            <div class="border rounded-3 p-3 h-100">
                                <div class="d-flex justify-content-between align-items-center gap-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width: 42px; height: 42px; background: @(string.IsNullOrWhiteSpace(user.AvatarColor) ? "#3B7DD8" : user.AvatarColor);">
                                            @user.Initials
                                        </div>
                                        <div>
                                            <div class="fw-bold">@user.Name</div>
                                            <div class="text-muted small">@user.Email</div>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="small fw-semibold">@user.Role</div>
                                        <div class="text-muted small">@user.GradeOrPosition</div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    }
}
