@{
    ViewData["Title"] = "School Management";
    ViewData["ActivePage"] = "Schools";

    var schools = ViewBag.Schools as List<dynamic> ?? new List<dynamic>();

    var ySchoolCount = (int)(ViewBag.YesterdaySchoolCount ?? 0);
    var yActiveSchools = (int)(ViewBag.YesterdayActiveSchools ?? 0);
    var yTotalUsers = (int)(ViewBag.YesterdayTotalUsers ?? 0);
    var yTotalResources = (int)(ViewBag.YesterdayTotalResources ?? 0);

    string KpiChange(int current, int yesterday)
    {
        var diff = current - yesterday;
        if (yesterday == 0) return diff > 0 ? $"+{diff} new today" : "No change";
        var pct = Math.Abs((double)diff / yesterday * 100);
        var dir = diff >= 0 ? "+" : "-";
        return $"{dir}{pct:0.#}% vs yesterday";
    }
    bool KpiPositive(int current, int yesterday) => current >= yesterday;
}

<!-- Page Header -->
<div class="ll-page-header">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="ll-page-title">School Management</h1>
            <div class="ll-breadcrumb">
                <a href="@Url.Action("Dashboard", "Home")">Dashboard</a>
                <i class="bi bi-chevron-right small"></i>
                <span>Schools</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="ll-btn ll-btn-primary" data-bs-toggle="modal" data-bs-target="#createSchoolModal">
                <i class="bi bi-building-add"></i>
                Add School
            </button>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
<div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}
@if (TempData["ErrorMessage"] != null)
{
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}

<!-- Stats -->
<div class="row g-4 mb-4">
    <div class="col-6 col-sm-6 col-xl-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon primary">
                <i class="bi bi-building"></i>
            </div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@schools.Count</div>
                <div class="ll-stat-label">Total Schools</div>
                <div class="ll-stat-change @(KpiPositive(schools.Count, ySchoolCount) ? "positive" : "negative")">
                    <i class="bi bi-arrow-@(KpiPositive(schools.Count, ySchoolCount) ? "up" : "down")"></i>
                    @KpiChange(schools.Count, ySchoolCount)
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-6 col-xl-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon success">
                <i class="bi bi-check-circle"></i>
            </div>
            <div class="ll-stat-content">
                @{ var activeSchoolCount = schools.Count(s => (bool)s.IsActive); }
                <div class="ll-stat-value">@activeSchoolCount</div>
                <div class="ll-stat-label">Active Schools</div>
                <div class="ll-stat-change @(KpiPositive(activeSchoolCount, yActiveSchools) ? "positive" : "negative")">
                    <i class="bi bi-arrow-@(KpiPositive(activeSchoolCount, yActiveSchools) ? "up" : "down")"></i>
                    @KpiChange(activeSchoolCount, yActiveSchools)
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-6 col-xl-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon warning">
                <i class="bi bi-people"></i>
            </div>
            <div class="ll-stat-content">
                @{ var totalUserCount = schools.Sum(s => (int)s.UserCount); }
                <div class="ll-stat-value">@totalUserCount</div>
                <div class="ll-stat-label">Total Users</div>
                <div class="ll-stat-change @(KpiPositive(totalUserCount, yTotalUsers) ? "positive" : "negative")">
                    <i class="bi bi-arrow-@(KpiPositive(totalUserCount, yTotalUsers) ? "up" : "down")"></i>
                    @KpiChange(totalUserCount, yTotalUsers)
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-6 col-xl-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon info">
                <i class="bi bi-folder2-open"></i>
            </div>
            <div class="ll-stat-content">
                @{ var totalResourceCount = schools.Sum(s => (int)s.ResourceCount); }
                <div class="ll-stat-value">@totalResourceCount</div>
                <div class="ll-stat-label">Total Resources</div>
                <div class="ll-stat-change @(KpiPositive(totalResourceCount, yTotalResources) ? "positive" : "negative")">
                    <i class="bi bi-arrow-@(KpiPositive(totalResourceCount, yTotalResources) ? "up" : "down")"></i>
                    @KpiChange(totalResourceCount, yTotalResources)
                </div>
            </div>
        </div>
    </div>
</div>

<!-- School Switcher -->
<div class="ll-card mb-4">
    <div class="ll-card-body">
        <form asp-action="SwitchSchoolContext" method="post" class="d-flex align-items-center gap-3">
            <label class="fw-semibold text-nowrap"><i class="bi bi-eye me-1"></i>View As:</label>
            <select name="schoolId" class="ll-form-control ll-form-select" style="max-width: 300px;" onchange="this.form.submit()">
                <option value="">All Schools (Platform View)</option>
                @foreach (var school in schools)
                {
                    var switched = Context.Session.GetInt32("SwitchedSchoolId");
                    <option value="@school.SchoolId" selected="@(switched != null && switched == (int)school.SchoolId)">@school.Name (@school.Code)</option>
                }
            </select>
            <noscript><button type="submit" class="ll-btn ll-btn-primary">Switch</button></noscript>
        </form>
    </div>
</div>

<!-- Schools Table -->
<div class="ll-card">
    <div class="ll-card-header d-flex justify-content-between align-items-center">
        <h5 class="ll-card-title mb-0"><i class="bi bi-building me-2"></i>Registered Schools</h5>
    </div>
    <div class="ll-card-body p-0">
        <div class="table-responsive">
            <table class="table ll-table mb-0">
                <thead>
                    <tr>
                        <th>School</th>
                        <th>Code</th>
                        <th>Manager</th>
                        <th class="text-center">Users</th>
                        <th class="text-center">Resources</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Sharing</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (schools.Count == 0)
                    {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="bi bi-building display-6 d-block mb-2"></i>
                            No schools registered yet. Click "Add School" to create one.
                        </td>
                    </tr>
                    }
                    @foreach (var school in schools)
                    {
                    <tr>
                        <td>
                            <div class="fw-semibold">@school.Name</div>
                            @if (!string.IsNullOrEmpty((string)school.ContactEmail))
                            {
                            <div class="text-muted small">@school.ContactEmail</div>
                            }
                        </td>
                        <td><span class="badge bg-secondary">@school.Code</span></td>
                        <td class="small">@school.ManagerName</td>
                        <td class="text-center">
                            <span class="badge bg-primary bg-opacity-10 text-primary">@school.UserCount</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-info bg-opacity-10 text-info">@school.ResourceCount</span>
                        </td>
                        <td class="text-center">
                            <form asp-action="ToggleSchoolStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@school.SchoolId" />
                                <button type="submit" class="btn btn-sm @((bool)school.IsActive ? "btn-success" : "btn-secondary")" title="Click to toggle">
                                    <i class="bi @((bool)school.IsActive ? "bi-check-circle" : "bi-x-circle")"></i>
                                    @((bool)school.IsActive ? "Active" : "Inactive")
                                </button>
                            </form>
                        </td>
                        <td class="text-center">
                            <form asp-action="ToggleCrossSchoolSharing" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@school.SchoolId" />
                                <button type="submit" class="btn btn-sm @((bool)school.AllowCrossSchoolSharing ? "btn-info" : "btn-outline-secondary")" title="Click to toggle">
                                    <i class="bi @((bool)school.AllowCrossSchoolSharing ? "bi-share" : "bi-share")"></i>
                                    @((bool)school.AllowCrossSchoolSharing ? "On" : "Off")
                                </button>
                            </form>
                        </td>
                        <td class="text-center">
                            <form asp-action="SwitchSchoolContext" method="post" class="d-inline">
                                <input type="hidden" name="schoolId" value="@school.SchoolId" />
                                <button type="submit" class="btn btn-sm btn-outline-primary" title="Switch to this school's context">
                                    <i class="bi bi-box-arrow-in-right"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create School Modal -->
<div class="modal fade" id="createSchoolModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="CreateSchool" method="post">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-building-add me-2"></i>Add New School</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">School Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="form-control" placeholder="Enter the school's name" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">School Code <span class="text-danger">*</span></label>
                        <input type="text" name="code" class="form-control" placeholder="Enter the unique school code" maxlength="6" required>
                        <div class="form-text">Input numbers up to 6 digits.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="description" class="form-control" rows="2" placeholder="Description of the school"></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Contact Email</label>
                            <input type="email" name="contactEmail" class="form-control" placeholder="Enter email address">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Address</label>
                            <input type="text" name="address" class="form-control" placeholder="Enter school address">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Create School</button>
                </div>
            </form>
        </div>
    </div>
</div>
