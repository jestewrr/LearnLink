@{
    ViewData["Title"] = "Knowledge Sharing Portal";
    ViewData["ActivePage"] = "KnowledgePortal";

    var discussions = ViewBag.Discussions as List<LearnLink.Models.DiscussionViewModel> ?? new List<LearnLink.Models.DiscussionViewModel>();
    var popularTags = ViewBag.PopularTags as List<string> ?? new List<string>();
    var topContributors = ViewBag.TopContributors as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="row g-4">
    <!-- Left Sidebar -->
    <div class="col-lg-3 d-none d-lg-block">
        <div class="fb-sidebar-sticky">
            <!-- User Profile Card -->
            <div class="fb-card mb-3">
                <div class="fb-card-body text-center py-4">
                    <div class="fb-avatar-lg mx-auto mb-2" style="@(ViewBag.CurrentUserColor ?? "")">@(ViewBag.CurrentUserInitials ?? "?")</div>
                    <h6 class="fw-bold mb-1">@(ViewBag.CurrentUserName ?? "User")</h6>
                    <p class="text-muted small mb-0">Knowledge Sharing Portal</p>
                </div>
            </div>

            <!-- Quick Navigation -->
            <div class="fb-card mb-3">
                <div class="fb-card-body p-0">
                    <a href="@Url.Action("KnowledgePortal", "Home")" class="fb-nav-item active">
                        <i class="bi bi-house-door-fill"></i> News Feed
                    </a>
                    <a href="@Url.Action("Repository", "Home")" class="fb-nav-item">
                        <i class="bi bi-folder2-open"></i> Knowledge Repository
                    </a>
                    <a href="@Url.Action("LessonsLearned", "Home")" class="fb-nav-item">
                        <i class="bi bi-lightbulb"></i> Lessons Learned
                    </a>
                    <a href="@Url.Action("BestPractices", "Home")" class="fb-nav-item">
                        <i class="bi bi-star"></i> Best Practices
                    </a>
                </div>
            </div>

            <!-- Trending Topics -->
            @if (popularTags.Any())
            {
            <div class="fb-card">
                <div class="fb-card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-fire text-danger me-2"></i>Trending Topics</h6>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var tag in popularTags.Take(10))
                        {
                            <span class="fb-trending-tag">@tag</span>
                        }
                    </div>
                </div>
            </div>
            }
        </div>
    </div>

    <!-- Main Feed -->
    <div class="col-lg-6">
        <!-- Create Post Box -->
        <div class="fb-card mb-3">
            <div class="fb-card-body">
                <div class="d-flex gap-3 align-items-center mb-3">
                    <div class="fb-avatar" style="@(ViewBag.CurrentUserColor ?? "")">@(ViewBag.CurrentUserInitials ?? "?")</div>
                    <button class="fb-create-post-input" data-bs-toggle="modal" data-bs-target="#newDiscussionModal">
                        What's on your mind? Share knowledge...
                    </button>
                </div>
                <hr class="my-0 mb-3">
                <div class="d-flex justify-content-around">
                    <button class="fb-create-action" data-bs-toggle="modal" data-bs-target="#newDiscussionModal" onclick="setTimeout(()=>document.querySelector('.disc-type-btn[data-value=Question]')?.click(),300)">
                        <i class="bi bi-question-circle text-primary"></i> Ask Question
                    </button>
                    <button class="fb-create-action" data-bs-toggle="modal" data-bs-target="#newDiscussionModal" onclick="setTimeout(()=>document.querySelector('.disc-type-btn[data-value=Idea]')?.click(),300)">
                        <i class="bi bi-lightbulb text-warning"></i> Share Idea
                    </button>
                    <button class="fb-create-action" data-bs-toggle="modal" data-bs-target="#newDiscussionModal" onclick="setTimeout(()=>document.querySelector('.disc-type-btn[data-value=Resource]')?.click(),300)">
                        <i class="bi bi-file-earmark text-success"></i> Resource
                    </button>
                </div>
            </div>
        </div>

        <!-- Filter & Sort Bar -->
        <div class="fb-card mb-3">
            <div class="fb-card-body py-2">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <button class="fb-filter-pill active portal-filter-btn" data-type="">All</button>
                    <button class="fb-filter-pill portal-filter-btn" data-type="Question"><i class="bi bi-question-circle me-1"></i>Questions</button>
                    <button class="fb-filter-pill portal-filter-btn" data-type="Idea"><i class="bi bi-lightbulb me-1"></i>Ideas</button>
                    <button class="fb-filter-pill portal-filter-btn" data-type="Resource"><i class="bi bi-file-earmark me-1"></i>Resources</button>
                    <button class="fb-filter-pill portal-filter-btn" data-type="Study Group"><i class="bi bi-people me-1"></i>Study Groups</button>
                    <div class="ms-auto">
                        <select class="form-select form-select-sm border-0 text-muted" id="portalSortSelect" style="width:auto;">
                            <option value="recent">Most Recent</option>
                            <option value="likes">Most Liked</option>
                            <option value="comments">Most Active</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search -->
        <div class="fb-card mb-3">
            <div class="fb-card-body py-2">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" class="form-control border-0 bg-light rounded-pill ps-5" id="portalSearchInput" placeholder="Search discussions...">
                </div>
            </div>
        </div>

        <!-- Feed Posts -->
        <div id="portalDiscussionsList">
        @foreach (var discussion in discussions)
        {
            var typeIcon = discussion.Type == "Question" ? "bi-question-circle-fill text-primary"
                : discussion.Type == "Idea" ? "bi-lightbulb-fill text-warning"
                : discussion.Type == "Resource" ? "bi-file-earmark-fill text-success"
                : discussion.Type == "Study Group" ? "bi-people-fill text-info"
                : "bi-chat-fill text-secondary";
            var totalMins = (DateTime.Now - discussion.CreatedAt).TotalMinutes;
            var timeAgo = totalMins < 1 ? "Just now"
                : totalMins < 60 ? (int)totalMins + "m"
                : totalMins < 1440 ? (int)(DateTime.Now - discussion.CreatedAt).TotalHours + "h"
                : totalMins < 10080 ? (int)(DateTime.Now - discussion.CreatedAt).TotalDays + "d"
                : discussion.CreatedAt.ToString("MMM dd");

        <div class="fb-card fb-post-card mb-3 portal-discussion-item" data-type="@discussion.Type" data-likes="@discussion.LikeCount" data-comments="@discussion.ReplyCount" data-date="@discussion.CreatedAt.ToString("yyyy-MM-dd")" data-title="@discussion.Title.ToLower()">
            <!-- Post Header -->
            <div class="fb-card-body pb-0">
                <div class="d-flex align-items-start gap-3 mb-3">
                    <div class="fb-avatar" style="@(discussion.AuthorColor ?? "")">@discussion.AuthorInitials</div>
                    <div class="flex-fill">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-bold">@discussion.Author</span>
                            <i class="@typeIcon" style="font-size: 0.75rem;" title="@discussion.Type"></i>
                        </div>
                        <div class="small text-muted">@discussion.AuthorRole · @timeAgo · <i class="bi bi-globe2"></i></div>
                    </div>
                    @if (ViewBag.CurrentUserId != null && (ViewBag.CurrentUserId == discussion.UserId || User.IsInRole("SuperAdmin") || User.IsInRole("Manager")))
                    {
                    <div class="dropdown">
                        <button class="btn btn-sm btn-light rounded-circle" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li><a class="dropdown-item edit-disc-btn" href="#"
                                   data-id="@discussion.Id" data-title="@discussion.Title"
                                   data-content="@discussion.Content" data-type="@discussion.Type"
                                   data-tags="@string.Join(", ", discussion.Tags)"><i class="bi bi-pencil me-2"></i>Edit Post</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger delete-disc-btn" href="#" data-id="@discussion.Id"><i class="bi bi-trash me-2"></i>Delete Post</a></li>
                        </ul>
                    </div>
                    }
                </div>

                <!-- Post Content -->
                <a href="@Url.Action("Discussions", "Home", new { id = discussion.Id })" class="text-decoration-none">
                    <h6 class="fw-bold text-dark mb-2">@discussion.Title</h6>
                </a>
                <div class="fb-post-content mb-3">@Html.Raw(discussion.Content)</div>

                @if (discussion.Tags.Any())
                {
                <div class="d-flex flex-wrap gap-1 mb-3">
                    @foreach (var tag in discussion.Tags)
                    {
                        <span class="fb-tag">#@tag</span>
                    }
                </div>
                }
            </div>

            <!-- Engagement Summary -->
            <div class="fb-card-body py-2 border-top border-bottom">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="fb-likes-summary" @(discussion.LikeCount > 0 ? $"onclick=\"showLikers({discussion.Id}, 'Discussion')\" style=\"cursor:pointer\"" : "")>
                        @if (discussion.LikeCount > 0)
                        {
                            <span class="fb-like-icon-sm"><i class="bi bi-heart-fill"></i></span>
                            @if (discussion.LikerNames.Any())
                            {
                                var firstName = discussion.LikerNames.First();
                                var othersCount = discussion.LikeCount - 1;
                                @if (othersCount > 0)
                                {
                                    <span class="text-muted small">@firstName and @othersCount other@(othersCount > 1 ? "s" : "")</span>
                                }
                                else
                                {
                                    <span class="text-muted small">@firstName</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">@discussion.LikeCount</span>
                            }
                        }
                    </div>
                    <div class="d-flex gap-3">
                        @if (discussion.ReplyCount > 0)
                        {
                            <a href="@Url.Action("Discussions", "Home", new { id = discussion.Id })" class="text-muted small text-decoration-none">@discussion.ReplyCount comment@(discussion.ReplyCount > 1 ? "s" : "")</a>
                        }
                        @if (discussion.ViewCount > 0)
                        {
                            <span class="text-muted small">@discussion.ViewCount views</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Action Bar -->
            <div class="fb-card-body py-1">
                <div class="d-flex justify-content-around">
                    <button class="fb-action-btn portal-like-btn @(discussion.IsLiked ? "active" : "")" data-id="@discussion.Id">
                        <i class="bi @(discussion.IsLiked ? "bi-heart-fill" : "bi-heart")"></i> Like
                    </button>
                    <a href="@Url.Action("Discussions", "Home", new { id = discussion.Id })" class="fb-action-btn text-decoration-none">
                        <i class="bi bi-chat"></i> Comment
                    </a>
                    <button class="fb-action-btn fb-share-btn" data-id="@discussion.Id" data-title="@discussion.Title">
                        <i class="bi bi-share"></i> Share
                    </button>
                </div>
            </div>

            <!-- Inline Comments Preview -->
            @if (discussion.LatestReplies.Any())
            {
            <div class="fb-card-body pt-2 fb-comments-preview">
                @if (discussion.ReplyCount > 2)
                {
                    <a href="@Url.Action("Discussions", "Home", new { id = discussion.Id })" class="text-muted small fw-medium text-decoration-none d-block mb-2">View all @discussion.ReplyCount comments</a>
                }
                @foreach (var reply in discussion.LatestReplies)
                {
                <div class="d-flex gap-2 mb-2">
                    <div class="fb-avatar-sm" style="@(reply.AuthorColor ?? "")">@reply.AuthorInitials</div>
                    <div class="fb-comment-bubble">
                        <span class="fw-bold small">@reply.Author</span>
                        <span class="small">@Html.Raw(reply.Content)</span>
                    </div>
                </div>
                }
            </div>
            }

            <!-- Quick Comment Box -->
            <div class="fb-card-body pt-2">
                <div class="d-flex gap-2 align-items-center">
                    <div class="fb-avatar-sm" style="@(ViewBag.CurrentUserColor ?? "")">@(ViewBag.CurrentUserInitials ?? "?")</div>
                    <div class="fb-quick-comment-wrap">
                        <input type="text" class="fb-quick-comment" placeholder="Write a comment..." data-discussion-id="@discussion.Id">
                        <button class="fb-quick-comment-send" data-discussion-id="@discussion.Id"><i class="bi bi-send-fill"></i></button>
                    </div>
                </div>
            </div>
        </div>
        }
        </div>

        <!-- No Results -->
        <div class="text-center py-5 d-none" id="portalNoResults">
            <i class="bi bi-chat-square-text" style="font-size: 3rem; color: #cbd5e1;"></i>
            <h5 class="mt-3 text-muted">No discussions found</h5>
            <p class="text-muted small">Try adjusting your filter or start a new discussion.</p>
        </div>

        <!-- Load More -->
        <div class="text-center mt-3 mb-5">
            <button class="fb-load-more-btn">
                <i class="bi bi-arrow-clockwise me-1"></i> Load More
            </button>
        </div>
    </div>

    <!-- Right Sidebar -->
    <div class="col-lg-3 d-none d-lg-block">
        <div class="fb-sidebar-sticky">
            <!-- Active Contributors -->
            <div class="fb-card mb-3">
                <div class="fb-card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-people-fill text-primary me-2"></i>Active Contributors</h6>
                    @foreach (var c in topContributors)
                    {
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="fb-avatar-sm" style="@c.Color">@c.Initials</div>
                        <div class="flex-fill">
                            <div class="small fw-medium">@c.Name</div>
                            <div class="small text-muted">@c.Posts post@(c.Posts > 1 ? "s" : "")</div>
                        </div>
                    </div>
                    }
                    @if (!topContributors.Any())
                    {
                        <p class="text-muted small mb-0">No contributors yet.</p>
                    }
                </div>
            </div>

            <!-- Community Guidelines -->
            <div class="fb-card">
                <div class="fb-card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-shield-check text-success me-2"></i>Community Guidelines</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li class="mb-1">Be respectful and constructive</li>
                        <li class="mb-1">Share knowledge and resources</li>
                        <li class="mb-1">Ask questions, provide answers</li>
                        <li class="mb-1">Tag posts for easy discovery</li>
                        <li>Report inappropriate content</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- New Discussion Modal -->
<div class="modal fade" id="newDiscussionModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="PostDiscussion" method="post" id="newDiscussionForm">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Create Post</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex gap-3 align-items-center mb-3">
                        <div class="fb-avatar" style="@(ViewBag.CurrentUserColor ?? "")">@(ViewBag.CurrentUserInitials ?? "?")</div>
                        <div>
                            <div class="fw-bold">@(ViewBag.CurrentUserName ?? "User")</div>
                            <div class="d-flex gap-1 mt-1">
                                <input type="hidden" name="Type" id="discType" value="Question">
                                <button type="button" class="fb-type-pill disc-type-btn active" data-value="Question"><i class="bi bi-question-circle me-1"></i>Question</button>
                                <button type="button" class="fb-type-pill disc-type-btn" data-value="Idea"><i class="bi bi-lightbulb me-1"></i>Idea</button>
                                <button type="button" class="fb-type-pill disc-type-btn" data-value="Resource"><i class="bi bi-file-earmark me-1"></i>Resource</button>
                                <button type="button" class="fb-type-pill disc-type-btn" data-value="Study Group"><i class="bi bi-people me-1"></i>Study Group</button>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <input type="text" class="form-control border-0 fs-5 px-0" name="Title" placeholder="Title — What's this about?" required style="box-shadow:none;">
                    </div>
                    <div class="mb-3">
                        <textarea class="form-control border-0 px-0" rows="4" name="Content" placeholder="Share your thoughts, questions, or insights..." required style="box-shadow:none; resize:none;"></textarea>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <select class="form-select form-select-sm" name="Category">
                                <option value="">Subject (optional)</option>
                                <option>Mathematics</option>
                                <option>Science</option>
                                <option>English</option>
                                <option>Filipino</option>
                                <option>History</option>
                                <option>MAPEH</option>
                                <option>TLE</option>
                                <option>General</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control form-control-sm" name="Tags" id="newDiscTags" placeholder="Tags (comma-separated)" value="General">
                        </div>
                    </div>
                    @if (popularTags.Any())
                    {
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var pTag in popularTags.Take(8))
                        {
                            <button type="button" class="fb-tag-suggest ll-tag-suggest" data-target="newDiscTags">#@pTag</button>
                        }
                    </div>
                    }
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2">Post</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Discussion Modal -->
<div class="modal fade" id="editDiscussionModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="EditDiscussion" method="post">
                <input type="hidden" name="id" id="editDiscId">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Edit Post</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <input type="hidden" name="Type" id="editDiscType">
                        <div class="d-flex gap-1">
                            <button type="button" class="fb-type-pill edit-disc-type-btn" data-value="Question">Question</button>
                            <button type="button" class="fb-type-pill edit-disc-type-btn" data-value="Idea">Idea</button>
                            <button type="button" class="fb-type-pill edit-disc-type-btn" data-value="Resource">Resource</button>
                            <button type="button" class="fb-type-pill edit-disc-type-btn" data-value="Study Group">Study Group</button>
                            <button type="button" class="fb-type-pill edit-disc-type-btn" data-value="General">General</button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <input type="text" class="form-control border-0 fs-5 px-0" name="Title" id="editDiscTitle" required style="box-shadow:none;">
                    </div>
                    <div class="mb-3">
                        <textarea class="form-control border-0 px-0" rows="4" name="Content" id="editDiscContent" required style="box-shadow:none; resize:none;"></textarea>
                    </div>
                    <div class="mb-3">
                        <input type="text" class="form-control form-control-sm" name="Tags" id="editDiscTags" placeholder="Tags (comma-separated)">
                    </div>
                    @if (popularTags.Any())
                    {
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var pTag in popularTags.Take(8))
                        {
                            <button type="button" class="fb-tag-suggest ll-tag-suggest" data-target="editDiscTags">#@pTag</button>
                        }
                    </div>
                    }
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill fw-bold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Discussion Modal -->
<div class="modal fade" id="deleteDiscussionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">
            <form asp-action="DeleteDiscussion" method="post">
                <input type="hidden" name="id" id="deleteDiscId">
                <div class="modal-body text-center py-4">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold mt-3">Delete this post?</h5>
                    <p class="text-muted small">This action cannot be undone.</p>
                    <div class="d-flex gap-2 justify-content-center mt-3">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger rounded-pill px-4">Delete</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Likers Modal -->
<div class="modal fade" id="likersModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Likes</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="likersModalBody">
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1080;">
    <div id="portalToast" class="toast" role="alert">
        <div class="toast-header bg-success text-white border-0">
            <i class="bi bi-check-circle me-2"></i>
            <strong class="me-auto">Success</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body">@TempData["SuccessMessage"]</div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    const filterBtns = document.querySelectorAll('.portal-filter-btn');
    const items = document.querySelectorAll('.portal-discussion-item');
    const searchInput = document.getElementById('portalSearchInput');
    const sortSelect = document.getElementById('portalSortSelect');
    const list = document.getElementById('portalDiscussionsList');
    const noResults = document.getElementById('portalNoResults');

    function filterAndSort() {
        const activeBtn = document.querySelector('.portal-filter-btn.active');
        const typeFilter = activeBtn ? activeBtn.dataset.type : '';
        const query = searchInput.value.toLowerCase();
        let visibleCount = 0;
        const arr = Array.from(items);
        arr.forEach(item => {
            const matchType = !typeFilter || item.dataset.type === typeFilter;
            const matchSearch = !query || item.dataset.title.includes(query);
            const visible = matchType && matchSearch;
            item.classList.toggle('d-none', !visible);
            if (visible) visibleCount++;
        });
        arr.sort((a, b) => {
            switch (sortSelect.value) {
                case 'likes': return parseInt(b.dataset.likes) - parseInt(a.dataset.likes);
                case 'comments': return parseInt(b.dataset.comments) - parseInt(a.dataset.comments);
                default: return b.dataset.date.localeCompare(a.dataset.date);
            }
        });
        arr.forEach(item => list.appendChild(item));
        noResults.classList.toggle('d-none', visibleCount > 0);
    }

    filterBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            filterBtns.forEach(b => { b.classList.remove('active'); });
            this.classList.add('active');
            filterAndSort();
        });
    });
    searchInput.addEventListener('input', filterAndSort);
    sortSelect.addEventListener('change', filterAndSort);

    // Discussion type buttons in modals
    document.querySelectorAll('.disc-type-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.disc-type-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            document.getElementById("discType").value = this.dataset.value;
        });
    });
    document.querySelectorAll('.edit-disc-type-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.edit-disc-type-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            document.getElementById("editDiscType").value = this.dataset.value;
        });
    });

    // Like Logic
    document.querySelectorAll('.portal-like-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const id = this.dataset.id;
            const btnEl = this;
            const icon = btnEl.querySelector('i');
            fetch('@Url.Action("LikeDiscussion", "Home")?id=' + id, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        if (data.isLiked) {
                            icon.classList.replace('bi-heart', 'bi-heart-fill');
                            btnEl.classList.add('active');
                        } else {
                            icon.classList.replace('bi-heart-fill', 'bi-heart');
                            btnEl.classList.remove('active');
                        }
                        // Update engagement summary
                        const card = btnEl.closest('.fb-post-card');
                        const summary = card.querySelector('.fb-likes-summary');
                        if (data.likes > 0) {
                            summary.innerHTML = '<span class="fb-like-icon-sm"><i class="bi bi-heart-fill"></i></span><span class="text-muted small">' + data.likes + '</span>';
                            summary.style.cursor = 'pointer';
                            summary.onclick = function() { showLikers(id, 'Discussion'); };
                        } else {
                            summary.innerHTML = '';
                            summary.style.cursor = '';
                            summary.onclick = null;
                        }
                    }
                });
        });
    });

    // Quick Comment (inline)
    document.querySelectorAll('.fb-quick-comment').forEach(input => {
        input.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && this.value.trim()) {
                e.preventDefault();
                submitQuickComment(this);
            }
        });
    });
    document.querySelectorAll('.fb-quick-comment-send').forEach(btn => {
        btn.addEventListener('click', function() {
            const input = this.parentElement.querySelector('.fb-quick-comment');
            if (input.value.trim()) submitQuickComment(input);
        });
    });

    function submitQuickComment(input) {
        const discussionId = input.dataset.discussionId;
        const content = input.value.trim();
        input.disabled = true;
        fetch('@Url.Action("QuickReply", "Home")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'discussionId=' + discussionId + '&content=' + encodeURIComponent(content)
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const card = input.closest('.fb-post-card');
                let preview = card.querySelector('.fb-comments-preview');
                if (!preview) {
                    preview = document.createElement('div');
                    preview.className = 'fb-card-body pt-2 fb-comments-preview';
                    input.closest('.fb-card-body').before(preview);
                }
                const commentHtml = '<div class="d-flex gap-2 mb-2">' +
                    '<div class="fb-avatar-sm" style="' + (data.reply.color || '') + '">' + data.reply.initials + '</div>' +
                    '<div class="fb-comment-bubble">' +
                    '<span class="fw-bold small">' + data.reply.author + '</span> ' +
                    '<span class="small">' + data.reply.content + '</span>' +
                    '</div></div>';
                preview.insertAdjacentHTML('beforeend', commentHtml);
                input.value = '';
            }
            input.disabled = false;
            input.focus();
        })
        .catch(() => { input.disabled = false; });
    }

    // Edit/Delete Interactions
    document.querySelectorAll('.edit-disc-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault(); e.stopPropagation();
            document.getElementById('editDiscId').value = this.dataset.id;
            document.getElementById('editDiscTitle').value = this.dataset.title;
            document.getElementById('editDiscContent').value = this.dataset.content;
            document.getElementById('editDiscType').value = this.dataset.type;
            document.getElementById('editDiscTags').value = this.dataset.tags || '';
            document.querySelectorAll('.edit-disc-type-btn').forEach(b => {
                b.classList.toggle('active', b.dataset.value === this.dataset.type);
            });
            new bootstrap.Modal(document.getElementById('editDiscussionModal')).show();
        });
    });
    document.querySelectorAll('.delete-disc-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault(); e.stopPropagation();
            document.getElementById('deleteDiscId').value = this.dataset.id;
            new bootstrap.Modal(document.getElementById('deleteDiscussionModal')).show();
        });
    });

    // Tag suggestions
    document.querySelectorAll('.ll-tag-suggest').forEach(btn => {
        btn.addEventListener('click', function() {
            const input = document.getElementById(this.dataset.target);
            if (input) {
                const tagToAdd = this.textContent.replace('#', '').trim();
                const tags = input.value.split(',').map(t => t.trim().toLowerCase());
                if (!tags.includes(tagToAdd.toLowerCase())) {
                    input.value = input.value.trim() ? input.value + ', ' + tagToAdd : tagToAdd;
                }
            }
        });
    });

    // Share button (copy link)
    document.querySelectorAll('.fb-share-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const url = window.location.origin + '@Url.Action("Discussions", "Home")/' + this.dataset.id;
            navigator.clipboard.writeText(url).then(() => {
                const toast = new bootstrap.Toast(document.getElementById('portalToast'));
                document.querySelector('#portalToast .toast-body').textContent = 'Link copied to clipboard!';
                toast.show();
            });
        });
    });

    // Show Likers Modal
    window.showLikers = function(id, type) {
        const modal = new bootstrap.Modal(document.getElementById('likersModal'));
        const body = document.getElementById('likersModalBody');
        body.innerHTML = '<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary"></div></div>';
        modal.show();
        fetch('@Url.Action("GetDiscussionLikers", "Home")?id=' + id + '&type=' + type)
            .then(r => r.json())
            .then(likers => {
                if (likers.length === 0) {
                    body.innerHTML = '<p class="text-muted text-center">No likes yet.</p>';
                    return;
                }
                body.innerHTML = likers.map(l =>
                    '<div class="d-flex align-items-center gap-3 mb-3">' +
                    '<div class="fb-avatar" style="' + (l.color || '') + '">' + l.initials + '</div>' +
                    '<div><div class="fw-bold">' + l.name + '</div><div class="small text-muted">' + l.role + '</div></div>' +
                    '</div>'
                ).join('');
            });
    };

    // Server-side toast trigger
    var hasSuccess = '@(TempData["SuccessMessage"] != null ? "true" : "false")' === 'true';
    if (hasSuccess) {
        var toast = new bootstrap.Toast(document.getElementById('portalToast'));
        toast.show();
    }
})();
</script>
}
