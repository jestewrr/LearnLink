<!-- Rejection Reason Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="rejectForm" method="post">
                <div class="modal-header" style="background: #fee2e2; border-bottom: none;">
                    <div class="d-flex align-items-center gap-2">
                        <div style="width: 36px; height: 36px; background: #fecaca; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-x-circle-fill text-danger"></i>
                        </div>
                        <h6 class="modal-title fw-bold mb-0">Reject Resource</h6>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted mb-3">You are about to reject <strong id="rejectResourceTitle"></strong>. Please provide a reason for the contributor.</p>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Reason for Rejection</label>
                        <textarea class="form-control" name="reason" id="rejectReason" rows="3" placeholder="e.g. Content does not meet quality standards, missing references, incorrect formatting..." style="resize: none;"></textarea>
                    </div>
                    <div class="alert alert-warning py-2 small mb-0">
                        <i class="bi bi-info-circle me-1"></i> The contributor will be notified with this reason.
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger"><i class="bi bi-x-lg me-1"></i>Reject Resource</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function escHtml(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function formatPreviewDescription(value) {
        var raw = String(value ?? '');
        if (!raw.trim()) {
            return '';
        }

        var normalized = raw
            .replace(/<\/p>\s*<p[^>]*>/gi, '\n\n')
            .replace(/<br\s*\/?>/gi, '\n');

        var temp = document.createElement('div');
        temp.innerHTML = normalized;

        return escHtml(temp.textContent || temp.innerText || '')
            .replace(/\n{3,}/g, '\n\n')
            .replace(/\n/g, '<br>');
    }

    function updateReviewIndicators(resourceId, previewedAt) {
        document.querySelectorAll('[data-review-window="' + resourceId + '"]').forEach(function (element) {
            element.classList.remove('urgent');
            element.classList.add('previewed');
            element.innerHTML = '<i class="bi bi-eye-fill"></i><span>Previewed ' + escHtml(previewedAt) + '</span>';
        });

        document.querySelectorAll('[data-review-due="' + resourceId + '"]').forEach(function (element) {
            element.classList.add('d-none');
        });
    }

    function renderPendingPreviewViewer(data) {
        var viewerBody = document.getElementById('pendingPreviewViewerBody');
        var viewerLabel = document.getElementById('pendingPreviewViewerLabel');
        viewerBody.innerHTML = '';

        var format = (data.fileFormat || '').toUpperCase();
        var imageFormats = ['JPG', 'JPEG', 'PNG', 'GIF', 'WEBP', 'BMP', 'SVG'];

        if (data.previewUrl) {
            viewerLabel.textContent = data.formatLabel || 'Preview';

            if (imageFormats.indexOf(format) >= 0) {
                var img = document.createElement('img');
                img.src = data.previewUrl;
                img.alt = data.title || 'Resource preview';
                img.className = 'll-admin-preview-image';
                viewerBody.appendChild(img);
                return;
            }

            var frame = document.createElement('iframe');
            frame.src = data.previewUrl;
            frame.className = 'll-admin-preview-frame';
            frame.setAttribute('title', (data.title || 'Resource') + ' preview');
            frame.setAttribute('loading', 'lazy');
            viewerBody.appendChild(frame);
            return;
        }

        var empty = document.createElement('div');
        empty.className = 'll-scribd-viewer-empty';
        empty.innerHTML = '<i class="bi bi-file-earmark-lock2"></i><div class="fw-semibold mb-2">No inline preview available</div><p class="mb-0 text-center px-3">Use the detail page or source link below to inspect this resource.</p>';
        viewerBody.appendChild(empty);
        viewerLabel.textContent = 'Preview unavailable';
    }

    async function openPendingPreviewModal(id) {
        var overlay = document.getElementById('pendingPreviewOverlay');
        overlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';

        document.getElementById('pendingPreviewTitle').textContent = 'Loading...';
        document.getElementById('pendingPreviewUploader').innerHTML = '';
        document.getElementById('pendingPreviewTags').innerHTML = '';
        document.getElementById('pendingPreviewStats').innerHTML = '';
        document.getElementById('pendingPreviewDesc').innerHTML = '';
        document.getElementById('pendingPreviewFileInfo').innerHTML = '';
        document.getElementById('pendingPreviewViewerBody').innerHTML = '';
        document.getElementById('pendingPreviewViewerLabel').textContent = 'Loading preview...';

        try {
            var res = await fetch('@Url.Action("ResourcePreviewApi", "Home")?id=' + id);
            if (!res.ok) {
                throw new Error('Preview lookup failed');
            }

            var data = await res.json();
            document.getElementById('pendingPreviewTitle').textContent = data.title || 'Untitled resource';
            document.getElementById('pendingPreviewUploader').innerHTML = 'Uploaded by <strong>' + escHtml(data.uploader || 'Unknown') + '</strong>';

            var statsHtml = '<span class="ll-scribd-stat"><i class="bi bi-file-earmark-text"></i> ' + escHtml(data.formatLabel || 'Document') + '</span>';
            statsHtml += '<span class="ll-scribd-dot">&middot;</span><span class="ll-scribd-stat"><i class="bi bi-eye"></i> ' + Number(data.viewCount || 0).toLocaleString() + ' views</span>';
            if (data.reviewDueAt) {
                statsHtml += '<span class="ll-scribd-dot">&middot;</span><span class="ll-scribd-stat"><i class="bi bi-hourglass-split"></i> Due ' + escHtml(data.reviewDueAt) + '</span>';
            }
            document.getElementById('pendingPreviewStats').innerHTML = statsHtml;

            var tagsHtml = '';
            if (data.subject) tagsHtml += '<span class="ll-scribd-tag">' + escHtml(data.subject) + '</span>';
            if (data.gradeLevel) tagsHtml += '<span class="ll-scribd-tag">' + escHtml(data.gradeLevel) + '</span>';
            if (data.quarter) tagsHtml += '<span class="ll-scribd-tag">' + escHtml(data.quarter) + '</span>';
            if (data.resourceType) tagsHtml += '<span class="ll-scribd-tag">' + escHtml(data.resourceType) + '</span>';
            document.getElementById('pendingPreviewTags').innerHTML = tagsHtml;

            document.getElementById('pendingPreviewDesc').innerHTML = data.description
                ? formatPreviewDescription(data.description)
                : '<em class="text-muted">No description available.</em>';

            document.getElementById('pendingPreviewOpenBtn').href = data.detailUrl || '#';

            var sourceBtn = document.getElementById('pendingPreviewSourceBtn');
            if (data.sourceUrl) {
                sourceBtn.href = data.sourceUrl;
                sourceBtn.style.display = 'inline-flex';
                sourceBtn.querySelector('span').textContent = data.sourceLabel ? 'Open ' + data.sourceLabel : 'Open source';
            } else {
                sourceBtn.href = '#';
                sourceBtn.style.display = 'none';
            }

            renderPendingPreviewViewer(data);

            var infoHtml = '<div class="ll-scribd-file-row"><span>Uploaded</span><span>' + escHtml(data.createdAt || '') + '</span></div>';
            infoHtml += '<div class="ll-scribd-file-row"><span>File Size</span><span>' + escHtml(data.fileSize || 'Unknown') + '</span></div>';
            infoHtml += '<div class="ll-scribd-file-row"><span>Downloads</span><span>' + Number(data.downloadCount || 0).toLocaleString() + '</span></div>';
            if (data.reviewDueAt) {
                infoHtml += '<div class="ll-scribd-file-row"><span>Review Deadline</span><span>' + escHtml(data.reviewDueAt) + '</span></div>';
            }
            if (data.reviewPreviewedAt) {
                infoHtml += '<div class="ll-scribd-file-row"><span>First Preview</span><span>' + escHtml(data.reviewPreviewedAt) + '</span></div>';
                updateReviewIndicators(id, data.reviewPreviewedAt);
            } else if (typeof data.reviewDaysRemaining !== 'undefined') {
                infoHtml += '<div class="ll-scribd-file-row"><span>Time Remaining</span><span>' + Number(data.reviewDaysRemaining).toLocaleString() + ' day(s)</span></div>';
            }
            document.getElementById('pendingPreviewFileInfo').innerHTML = infoHtml;

            setTimeout(function () {
                overlay.querySelector('.ll-preview-modal').classList.add('ll-preview-visible');
            }, 10);
        } catch (error) {
            window.location.href = '@Url.Action("ResourceDetail", "Home")/' + id;
        }
    }

    function closePendingPreviewModal() {
        var overlay = document.getElementById('pendingPreviewOverlay');
        var modal = overlay.querySelector('.ll-preview-modal');
        modal.classList.remove('ll-preview-visible');
        setTimeout(function () {
            overlay.style.display = 'none';
            document.body.style.overflow = '';
        }, 250);
    }

    document.querySelectorAll('.pending-preview-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            openPendingPreviewModal(this.getAttribute('data-id'));
        });
    });

    document.getElementById('pendingPreviewOverlay').addEventListener('click', function (e) {
        if (e.target === this) {
            closePendingPreviewModal();
        }
    });

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && document.getElementById('pendingPreviewOverlay').style.display !== 'none') {
            closePendingPreviewModal();
        }
    });

    document.querySelectorAll('.reject-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var id = this.getAttribute('data-id');
            var title = this.getAttribute('data-title');
            document.getElementById('rejectResourceTitle').textContent = '"' + title + '"';
            document.getElementById('rejectForm').action = '/Home/RejectResource?id=' + id;
            document.getElementById('rejectReason').value = '';
            new bootstrap.Modal(document.getElementById('rejectModal')).show();
        });
    });
</script>
}
