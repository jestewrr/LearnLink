                <div class="ll-stat-change @(KpiPositive(stats?.ActiveDiscussions ?? 0, stats?.YesterdayDiscussions ?? 0) ? "positive" : "negative")">
                    <i class="bi bi-arrow-@(KpiPositive(stats?.ActiveDiscussions ?? 0, stats?.YesterdayDiscussions ?? 0) ? "up" : "down")"></i>
                    @KpiChange(stats?.ActiveDiscussions ?? 0, stats?.YesterdayDiscussions ?? 0)
