@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";

    var isAdmin = User.IsInRole("SuperAdmin");
    var isContributor = User.IsInRole("Contributor");
    var isManager = User.IsInRole("Manager");
    var canUpload = isAdmin || isContributor || isManager;
    var canAdmin = isAdmin; // Added definition

    var stats = ViewBag.Stats as LearnLink.Models.DashboardStatsViewModel;
    var recentResources = ViewBag.RecentResources as List<LearnLink.Models.ResourceViewModel> ?? new List<LearnLink.Models.ResourceViewModel>();
    var pendingApprovals = ViewBag.PendingApprovals as List<LearnLink.Models.ResourceViewModel> ?? new List<LearnLink.Models.ResourceViewModel>();
    var recentActivity = ViewBag.RecentActivity as List<LearnLink.Models.ActivityViewModel> ?? new List<LearnLink.Models.ActivityViewModel>();

    // Helper to compute KPI change text
    string KpiChange(int current, int yesterday)
    {
        var diff = current - yesterday;
        if (yesterday == 0) return diff > 0 ? $"+{diff} new today" : "No change";
        var pct = Math.Abs((double)diff / yesterday * 100);
        var dir = diff >= 0 ? "+" : "-";
        return $"{dir}{pct:0.#}% vs yesterday";
    }
    bool KpiPositive(int current, int yesterday) => current >= yesterday;
    DateTime ReviewDeadline(LearnLink.Models.ResourceViewModel resource) => resource.CreatedAt.AddDays(3);
    string ReviewCountdown(LearnLink.Models.ResourceViewModel resource)
    {
        if (resource.PendingReviewPreviewedAt.HasValue)
        {
            return $"Previewed {resource.PendingReviewPreviewedAt.Value:MMM dd, h:mm tt}";
        }

        var remaining = ReviewDeadline(resource) - DateTime.Now;
        if (remaining.TotalSeconds <= 0)
        {
            return "Expires now";
        }

        if (remaining.TotalHours < 24)
        {
            return $"{Math.Max(1, Math.Ceiling(remaining.TotalHours))} hour(s) left";
        }

        return $"{Math.Ceiling(remaining.TotalDays)} day(s) left";
    }
    string ReviewCountdownClass(LearnLink.Models.ResourceViewModel resource)
    {
        if (resource.PendingReviewPreviewedAt.HasValue)
        {
            return "previewed";
        }

        return (ReviewDeadline(resource) - DateTime.Now).TotalHours <= 24 ? "urgent" : string.Empty;
    }
}

<!-- Page Header -->
<div class="ll-page-header">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="ll-page-title">Dashboard</h1>
        </div>
        @if (canUpload)
        {
        <div class="d-flex gap-2">
            <a href="@Url.Action("Upload", "Home")" class="ll-btn ll-btn-primary">
                <i class="bi bi-cloud-arrow-up"></i>
                Upload Resource
            </a>
        </div>
        }
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-6 col-sm-6 col-xl-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon primary">
                <i class="bi bi-folder2-open"></i>
            </div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@(stats?.TotalResources.ToString("N0") ?? "0")</div>
                <div class="ll-stat-label">Total Resources</div>
                <div class="ll-stat-change @(KpiPositive(stats?.TotalResources ?? 0, stats?.YesterdayResources ?? 0) ? "positive" : "negative")">
                    <i class="bi bi-arrow-@(KpiPositive(stats?.TotalResources ?? 0, stats?.YesterdayResources ?? 0) ? "up" : "down")"></i>
                    @KpiChange(stats?.TotalResources ?? 0, stats?.YesterdayResources ?? 0)
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-6 col-xl-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon success">
                <i class="bi bi-download"></i>
            </div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@(stats?.TotalDownloads.ToString("N0") ?? "0")</div>
                <div class="ll-stat-label">Total Downloads</div>
                <div class="ll-stat-change @(KpiPositive(stats?.TotalDownloads ?? 0, stats?.YesterdayDownloads ?? 0) ? "positive" : "negative")">
                    <i class="bi bi-arrow-@(KpiPositive(stats?.TotalDownloads ?? 0, stats?.YesterdayDownloads ?? 0) ? "up" : "down")"></i>
