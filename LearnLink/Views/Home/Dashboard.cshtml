                    <i class="bi bi-arrow-@(KpiPositive(stats?.ActiveUsers ?? 0, stats?.YesterdayActiveUsers ?? 0) ? "up" : "down")"></i>
                    @KpiChange(stats?.ActiveUsers ?? 0, stats?.YesterdayActiveUsers ?? 0)
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-6 col-xl-3">
