@{
    ViewData["Title"] = "Too Many Requests - LearnLink";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="/images/LearnLink.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/learnlink.css" asp-append-version="true" />
</head>
<body class="ll-auth-body">
    <nav class="ll-auth-header">
        <div class="container-fluid px-4">
            <div class="d-flex align-items-center justify-content-between">
                <div class="ll-auth-logo">
                    <img src="/images/Learnlink.png" alt="LearnLink" />
                    <span class="ll-auth-logo-text"><span class="fw-bold">Learn</span><span style="color: var(--ll-accent, #E8B84B);">Link</span></span>
                </div>
                <a href="@Url.Action("Index", "Home")" class="ll-auth-nav-link"><i class="bi bi-house-door me-1"></i>Home</a>
            </div>
        </div>
    </nav>

    <div class="ll-auth-wrapper">
        <div class="container-fluid p-0">
            <div class="row g-0 justify-content-center">
                <div class="col-lg-5 ll-auth-right">
                    <div class="ll-auth-form-container">
                        <div class="ll-auth-form-card text-center">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 56px; height: 56px; background: #fee2e2;">
                                <i class="bi bi-shield-exclamation fs-4" style="color: #dc2626;"></i>
                            </div>

                            <h2 class="ll-auth-form-title">Too many attempts</h2>
                            <p class="ll-auth-form-subtitle mb-3">
                                For your security, we temporarily limited repeated requests from your connection.
                                Please wait a few minutes, then try again.
                            </p>

                            <div class="alert alert-warning small text-start mb-4" role="alert">
                                <i class="bi bi-clock-history me-2"></i>
                                Tip: If you forgot your password, use the reset option after the cooldown.
                            </div>

                            <div class="d-grid gap-2">
                                <a href="@Url.Action("Login", "Home")" class="btn ll-auth-btn-primary py-2">
                                    <i class="bi bi-arrow-repeat me-2"></i>Try Sign In Again
                                </a>
                                <a href="@Url.Action("ForgotPassword", "Home")" class="btn btn-outline-secondary py-2">
                                    <i class="bi bi-key me-2"></i>Forgot Password
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
