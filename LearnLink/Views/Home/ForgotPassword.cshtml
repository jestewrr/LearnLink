@{
    ViewData["Title"] = "Forgot Password - LearnLink";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="icon" type="image/png" href="/images/LearnLink.png" />
    <link rel="stylesheet" href="~/css/learnlink.css" asp-append-version="true" />
    @if (ViewBag.CaptchaEnabled == true)
    {
        <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    }
</head>
<body class="ll-auth-body">
    <nav class="ll-auth-header">
        <div class="container-fluid px-4">
            <div class="d-flex align-items-center justify-content-between">
                <div class="ll-auth-logo">
                    <img src="/images/Learnlink.png" alt="LearnLink" style="height: 64px; width: auto;" />
                    <span class="ll-auth-logo-text"><span class="fw-bold">Learn</span><span style="color: var(--ll-accent, #E8B84B);">Link</span></span>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <a href="@Url.Action("Index", "Home")" class="ll-auth-nav-link"><i class="bi bi-house-door me-1"></i>Home</a>
                    <div class="d-flex gap-2">
                        <a href="@Url.Action("Login", "Home")" class="btn btn-primary">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                        </a>
                        <a href="@Url.Action("Register", "Home")" class="btn fw-medium" style="background: var(--ll-accent, #E8B84B); color: #1e293b;">
                            <i class="bi bi-person-plus me-1"></i>Register
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="ll-auth-wrapper">
        <div class="container-fluid p-0">
            <div class="row g-0 justify-content-center">
                <div class="col-lg-5 ll-auth-right">
                    <div class="ll-auth-form-container">
                        <div class="ll-auth-form-card">
                            <div class="text-center mb-4">
                                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 56px; height: 56px; background: var(--ll-primary-light);">
                                    <i class="bi bi-envelope-check fs-4" style="color: var(--ll-primary);"></i>
                                </div>
                                <h2 class="ll-auth-form-title">Reset your password</h2>
                                <p class="ll-auth-form-subtitle mb-0">Enter your email and we will send you a reset link.</p>
                            </div>

                            @if (TempData["SuccessMessage"] != null)
                            {
                                <div class="alert alert-success d-flex align-items-center small py-2" role="alert">
                                    <i class="bi bi-check-circle-fill me-2"></i>
                                    @TempData["SuccessMessage"]
                                </div>
                            }

                            @if (TempData["ErrorMessage"] != null)
                            {
                                <div class="alert alert-danger d-flex align-items-center small py-2" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    @TempData["ErrorMessage"]
                                </div>
                            }

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger d-flex align-items-center small py-2" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    @ViewBag.Error
                                </div>
                            }

                            <form asp-action="ForgotPassword" method="post">
                                @Html.AntiForgeryToken()
                                <div class="mb-4">
                                    <label class="form-label">Email Address</label>
                                    <div class="ll-auth-input-group">
                                        <i class="bi bi-envelope ll-auth-input-icon"></i>
                                        <input type="email" name="email" class="form-control" placeholder="Enter your email" value="@(ViewBag.Email ?? string.Empty)" required>
                                    </div>
                                </div>

                                @if (ViewBag.CaptchaEnabled == true)
                                {
                                    <div class="mb-3 d-flex justify-content-center">
                                        <div class="g-recaptcha" data-sitekey="@ViewBag.CaptchaSiteKey"></div>
                                    </div>
                                }

                                <button type="submit" class="btn ll-auth-btn-primary w-100 py-2 mb-3">
                                    <i class="bi bi-send me-2"></i>Send Reset Link
                                </button>
                            </form>

                            <div class="text-center">
                                <span class="text-muted small">Remembered your password?</span>
                                <a href="@Url.Action("Login", "Home")" class="text-decoration-none small fw-semibold" style="color: var(--ll-primary);">Back to Sign In</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>