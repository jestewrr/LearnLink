@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Resource Detail";
    ViewData["ActivePage"] = "Repository";

    var resource = ViewBag.Resource as LearnLink.Models.ResourceViewModel;
    if (resource == null) return;
    var related = ViewBag.RelatedResources as List<LearnLink.Models.ResourceViewModel> ?? new List<LearnLink.Models.ResourceViewModel>();
    var fileUrl = ViewBag.FileUrl as string ?? string.Empty;
    var canPreview = (bool?)(ViewBag.CanPreview ?? false) ?? false;
    var allowDownloads = (bool?)(ViewBag.AllowDownloads ?? true) ?? true;
    var allowComments = (bool?)(ViewBag.AllowComments ?? true) ?? true;
    var allowRatings = (bool?)(ViewBag.AllowRatings ?? true) ?? true;
    var enableVersionHistory = (bool?)(ViewBag.EnableVersionHistory ?? true) ?? true;
    var isPublicView = (bool?)(ViewBag.IsPublicView ?? false) ?? false;
    var externalSourceUrl = ViewBag.ExternalSourceUrl as string ?? string.Empty;
    var externalPreviewUrl = ViewBag.ExternalPreviewUrl as string ?? string.Empty;
    var externalSourceLabel = ViewBag.ExternalSourceLabel as string ?? "External source";

    string Normal(string f) => f?.TrimStart('.').ToUpper() ?? "";

    string GetThumbnailGradient(string format) => Normal(format) switch
    {
        "PDF" => "background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%)",
        "DOCX" or "DOC" => "background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)",
        "PPTX" or "PPT" => "background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%)",
        "XLSX" or "XLS" => "background: linear-gradient(135deg, #10b981 0%, #059669 100%)",
        "LINK" => "background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)",
        _ => "background: linear-gradient(135deg, #8b5cf6) 0%, #7c3aed 100%)"
    };

    string GetThumbnailIcon(string format) => Normal(format) switch
    {
        "PDF" => "bi-file-earmark-pdf",
        "DOCX" or "DOC" => "bi-file-earmark-word",
        "PPTX" or "PPT" => "bi-file-earmark-ppt",
        "XLSX" or "XLS" => "bi-file-earmark-excel",
        "LINK" => "bi-link-45deg",
        _ => "bi-file-earmark"
    };

    string GetFormatLabel(string format) => Normal(format) switch
    {
        "PDF" => "PDF Document",
        "DOCX" or "DOC" => "Word Document",
        "PPTX" or "PPT" => "PowerPoint Presentation",
        "XLSX" or "XLS" => "Excel Spreadsheet",
        "LINK" => "External Link",
        _ => "Document"
    };
}

@{
    var fmt = Normal(resource.FileFormat);
    var isOffice = fmt == "DOCX" || fmt == "DOC" || fmt == "PPTX" || fmt == "PPT" || fmt == "XLSX" || fmt == "XLS";
    var isLink = fmt == "LINK";
    var hasFile = canPreview && !string.IsNullOrWhiteSpace(fileUrl);
    var isDriveFile = !string.IsNullOrEmpty(ViewBag.DriveFileId as string);
    var drivePreviewUrl = ViewBag.DrivePreviewUrl as string ?? "";
    var canUseGoogleViewer = fileUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase);
    var previewAction = isPublicView ? "PublicDownload" : "DownloadResource";

    var isImage = fmt is "JPG" or "JPEG" or "PNG" or "GIF" or "WEBP" or "BMP" or "SVG";
    string viewerUrl = "";
    string directImageUrl = "";
    bool showExternalLinkBlock = false;

    if (hasFile)
    {
        if (isLink)
        {
            viewerUrl = externalPreviewUrl;
            showExternalLinkBlock = string.IsNullOrWhiteSpace(externalPreviewUrl);
        }
        else if (isDriveFile && isImage)
        {
            // Images from Drive: use export=view URL for inline display
            var driveId = ViewBag.DriveFileId as string;
            directImageUrl = $"https://drive.google.com/uc?export=view&id={driveId}";
        }
        else if (isDriveFile)
        {
            // All Drive files: use Google Drive's native preview (handles PDF, Office, etc. reliably)
            viewerUrl = drivePreviewUrl;
        }
        else if (fmt == "PDF")
        {
            viewerUrl = Url.Action(previewAction, "Home", new { id = resource.Id, inline = true }) + "#view=FitH";
        }
        else if (isOffice)
        {
            // Local Office files: DO NOT use inline download proxy directly in iframe! It triggers immediate download.
            var req = Context.Request;
            var isLocalhost = req.Host.Host == "localhost" || req.Host.Host == "127.0.0.1";
            if (isLocalhost) {
                // Microsoft Office Online Viewer cannot access localhost. Skip viewer to show secure fallback.
                viewerUrl = "";
            } else {
                // We MUST pass a static public URL for Microsoft Office Online Viewer because it accesses the URL anonymously.
                // Action routes like DownloadResource with [Authorize] will cause a 302 to Login and break the viewer.
                var fullUrl = $"{req.Scheme}://{req.Host}{fileUrl}";
                viewerUrl = "https://view.officeapps.live.com/op/embed.aspx?src=" + Uri.EscapeDataString(fullUrl);
            }
        }
        else if (isImage)
        {
            directImageUrl = Url.Action(previewAction, "Home", new { id = resource.Id, inline = true }) ?? "";
        }
        else
        {
            // For unknown formats (zip, rar) or unavailable viewers, leave viewerUrl blank.
            // This triggers the fallback "Cannot be previewed" UI instead of an automatic browser download.
            viewerUrl = "";
        }
    }
}


@if (TempData["ErrorMessage"] != null)
{
<div class="alert alert-warning alert-dismissible fade show mt-2" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    @TempData["ErrorMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}

<!-- ═══════════ SCRIBD-STYLE READER LAYOUT ═══════════ -->
<div class="ll-reader-layout">
    <!-- ── LEFT SIDEBAR: Metadata ── -->
    <div class="ll-reader-sidebar-left">
        <!-- Stats -->
        <div class="ll-reader-meta-stats">
            @{
                int ratingPct = resource.Rating > 0 ? (int)Math.Round((resource.Rating / 5.0) * 100) : 0;
            }
            @if (resource.RatingCount > 0)
            {
                <span><i class="bi bi-hand-thumbs-up-fill"></i> @(ratingPct)% (@resource.RatingCount)</span>
                <span>&middot;</span>
            }
            <span>@resource.ViewCount.ToString("N0") views</span>
            <span>&middot;</span>
            <span>@GetFormatLabel(resource.FileFormat)</span>
        </div>

        <!-- Title -->
        <h1 class="ll-reader-meta-title">@resource.Title</h1>

        <!-- Description -->
        <div class="ll-reader-meta-desc" id="readerDesc">
            @Html.Raw(resource.Description)
        </div>
        <button class="ll-reader-desc-toggle" id="readerDescToggle" onclick="toggleReaderDesc()" style="display:none;">Full description</button>

        <!-- Uploader -->
        <div class="ll-reader-meta-uploader">
            Uploaded by <strong>@resource.Uploader</strong> on @resource.CreatedAt.ToString("MMM dd, yyyy")
        </div>

        @if (isLink && !string.IsNullOrWhiteSpace(externalSourceUrl))
        {
        <div class="ll-reader-meta-source-link">
            <span>Source:</span>
            <a href="@externalSourceUrl" target="_blank" rel="noopener noreferrer">@externalSourceLabel</a>
        </div>
        }

        <hr class="ll-reader-meta-divider" />

        <!-- Tags -->
        <div class="ll-scribd-tags" style="margin-bottom:14px;">
            <a class="ll-scribd-tag ll-scribd-tag-link" href="@Url.Action("Tag", "Home", new { tag = resource.Subject })">@resource.Subject</a>
            <span class="ll-scribd-tag">@resource.GradeLevel</span>
            @if (!string.IsNullOrEmpty(resource.Quarter))
            {
                <span class="ll-scribd-tag">@resource.Quarter</span>
            }
            <span class="ll-scribd-tag">@resource.ResourceType</span>
            @foreach (var cat in resource.Categories)
            {
                <span class="ll-scribd-tag ll-scribd-tag-cat"><i class="bi bi-folder me-1"></i>@cat</span>
            }
            @foreach (var tag in resource.Tags)
            {
                <a class="ll-scribd-tag ll-scribd-tag-hash ll-scribd-tag-link" href="@Url.Action("Tag", "Home", new { tag })"><i class="bi bi-hash"></i>@tag</a>
            }
        </div>

        <hr class="ll-reader-meta-divider" />

        <!-- Action Buttons Grid -->
        <div class="ll-reader-action-grid">
            @if (allowDownloads)
            {
            <button class="ll-reader-action-btn ll-detail-action-download" onclick="downloadResource(@resource.Id)">
                <i class="bi bi-download"></i>
                Download
            </button>
            }
            @if (!isPublicView)
            {
            <button class="ll-reader-action-btn @(resource.IsSaved ? "active" : "")" id="saveBtn" onclick="toggleSave(this, @resource.Id)">
                <i class="bi @(resource.IsSaved ? "bi-bookmark-fill" : "bi-bookmark")"></i>
                <span>@(resource.IsSaved ? "Saved" : "Save")</span>
            </button>
            }
            @if (!isPublicView)
            {
            <button class="ll-reader-action-btn @((bool)(ViewBag.IsCompleted ?? false) ? "active" : "")" id="markCompleteBtn" onclick="markComplete(@resource.Id)">
                <i class="bi @((bool)(ViewBag.IsCompleted ?? false) ? "bi-check-circle-fill" : "bi-check-circle")"></i>
                <span>@((bool)(ViewBag.IsCompleted ?? false) ? "Completed" : "Complete")</span>
            </button>
            }
            @if (!isPublicView)
            {
            <button class="ll-reader-action-btn @(resource.IsLiked ? "active" : "")" id="likeBtn" onclick="toggleLike(this, @resource.Id)">
                <i class="bi @(resource.IsLiked ? "bi-heart-fill" : "bi-heart")"></i>
                <span>@(resource.IsLiked ? "Liked" : "Like")</span>
            </button>
            }
        </div>

        <!-- Rating Widget -->
        @if (!isPublicView && allowRatings)
        {
        <div class="ll-scribd-rating-widget" id="ratingWidget" style="margin-top:28px;">
            <span class="ll-scribd-rating-label">Rate this resource</span>
            <div class="ll-reader-stars">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="bi bi-star ll-reader-star" data-value="@i" onclick="setRating(@resource.Id, @i)"></i>
                }
            </div>
            @if (resource.Rating > 0)
            {
                <span class="ll-scribd-rating-info">
                    <span id="ratingScore">@resource.Rating.ToString("0.0")</span>/5
                    <span class="text-muted" id="ratingStatsCount">(@resource.RatingCount ratings)</span>
                </span>
            }
            else
            {
                <span class="ll-scribd-rating-info text-muted" id="ratingStatsCount">No ratings yet</span>
            }
        </div>
        }

        <!-- File Info -->
        <div class="ll-scribd-file-info" style="margin-top:14px;">
            <div class="ll-scribd-file-row"><span>Format</span><span>@GetFormatLabel(resource.FileFormat)</span></div>
            <div class="ll-scribd-file-row"><span>File Size</span><span>@resource.FileSize</span></div>
            <div class="ll-scribd-file-row"><span>Subject</span><span>@resource.Subject</span></div>
            <div class="ll-scribd-file-row"><span>Grade Level</span><span>@resource.GradeLevel</span></div>
            <div class="ll-scribd-file-row"><span>Type</span><span>@resource.ResourceType</span></div>
            @if (!string.IsNullOrEmpty(resource.Quarter))
            {
            <div class="ll-scribd-file-row"><span>Quarter</span><span>@resource.Quarter</span></div>
            }
            <div class="ll-scribd-file-row"><span>Uploaded</span><span>@resource.CreatedAt.ToString("MMM dd, yyyy")</span></div>
        </div>

        <!-- Version History -->
        @if (enableVersionHistory && ViewBag.ResourceVersions != null)
        {
            var versions = ViewBag.ResourceVersions as IEnumerable<LearnLink.Models.ResourceVersion>;
            if (versions != null && versions.Any())
            {
                <details class="ll-scribd-versions" style="margin-top:14px;" open>
                    <summary><i class="bi bi-clock-history me-2"></i>Version History (@versions.Count())</summary>
                    <div class="ll-scribd-versions-list">
                        @{ var versionList = versions.ToList(); }
                        @for (int vi = 0; vi < versionList.Count; vi++)
                        {
                            var v = versionList[vi];
                            var isLatest = vi == 0;
                            var prevVersion = vi < versionList.Count - 1 ? versionList[vi + 1] : null;
                            <div class="ll-scribd-version-item" style="@(isLatest ? "border-left: 3px solid var(--ll-primary); padding-left: 10px;" : "")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <strong style="color:var(--ll-primary);font-size:0.85rem;">
                                        @v.VersionNumber
                                        @if (isLatest)
                                        {
                                            <span class="badge bg-primary ms-1" style="font-size:0.65rem;">Current</span>
                                        }
                                    </strong>
                                    <span class="text-muted" style="font-size:0.8rem;">@v.DateUpdated.ToString("MMM dd, yyyy")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(v.VersionNotes))
                                {
                                    <div class="small bg-light p-2 rounded mt-1" style="border-left:3px solid var(--ll-primary);font-size:0.78rem;">@v.VersionNotes</div>
                                }
                                @if (prevVersion != null && !string.IsNullOrEmpty(v.Title) && !string.IsNullOrEmpty(prevVersion.Title))
                                {
                                    var changes = new List<string>();
                                    if (v.Title != prevVersion.Title) changes.Add("Title");
                                    if (v.Description != prevVersion.Description) changes.Add("Description");
                                    if (v.Subject != prevVersion.Subject) changes.Add("Subject");
                                    if (v.GradeLevel != prevVersion.GradeLevel) changes.Add("Grade Level");
                                    if (v.ResourceType != prevVersion.ResourceType) changes.Add("Type");
                                    if (v.Quarter != prevVersion.Quarter) changes.Add("Quarter");
                                    if (v.FilePath != prevVersion.FilePath) changes.Add("File");
                                    if (changes.Any())
                                    {
                                        <div class="small text-info mt-1" style="font-size:0.75rem;">
                                            <i class="bi bi-pencil-square me-1"></i>Changed: @string.Join(", ", changes)
                                        </div>
                                    }
                                }
                                <div class="small text-muted mt-1"><i class="bi @GetThumbnailIcon(v.FileFormat)"></i> @v.FileFormat.ToUpper() · @v.FileSize</div>
                            </div>
                        }
                    </div>
                </details>
            }
        }

        @if (isPublicView)
        {
        <div style="margin-top:20px;">
            <a href="@Url.Action("Register", "Home")" class="ll-btn ll-btn-primary w-100" style="text-decoration:none;justify-content:center;">
                <i class="bi bi-person-plus me-2"></i>Sign up for full access
            </a>
        </div>
        }
    </div>

    <!-- ── CENTER: Document Viewer ── -->
    <div class="ll-reader-main">
        <!-- Toolbar -->
        <div class="ll-reader-toolbar">
            <div class="ll-reader-toolbar-left">
                <div class="ll-reader-toolbar-icon" style="@GetThumbnailGradient(resource.FileFormat)">
                    <i class="bi @GetThumbnailIcon(resource.FileFormat)"></i>
                </div>
                <div>
                    <div class="ll-reader-toolbar-title">@resource.Title</div>
                    <div class="ll-reader-toolbar-sub">@resource.FileSize · @resource.FileFormat.ToUpper()</div>
                </div>
            </div>
            <div class="ll-reader-toolbar-actions">
                @if (allowDownloads)
                {
                <button class="ll-detail-action-download" onclick="downloadResource(@resource.Id)" title="Download">
                    <i class="bi bi-download"></i>
                </button>
                }
                <a href="@Url.Action("Repository", "Home")" title="Back to Repository">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>

        <!-- Viewer Frame -->
        <div class="ll-reader-viewer-frame">
            @if (!hasFile)
            {
                <div class="ll-reader-no-preview">
                    <i class="bi bi-cloud-slash"></i>
                    <p>No file has been attached to this resource yet.</p>
                </div>
            }
            else if (showExternalLinkBlock)
            {
                <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;background:transparent;">
                    <div style="background:linear-gradient(135deg,#3b82f6,#2563eb);width:80px;height:80px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;box-shadow:0 10px 15px -3px rgba(59,130,246,0.3);">
                        <i class="bi bi-link-45deg" style="font-size:3.5rem;color:white;"></i>
                    </div>
                    <h4 class="fw-bold mb-2">External Link</h4>
                    <p class="text-muted mb-4" style="max-width:400px;text-align:center;">This resource is hosted on an external platform (like Google Books or Open Library).</p>
                    <a href="@fileUrl" target="_blank" class="ll-btn ll-btn-primary" style="text-decoration:none;padding:12px 24px;">
                        Open Link <i class="bi bi-box-arrow-up-right ms-2"></i>
                    </a>
                </div>
            }
            else if (!string.IsNullOrEmpty(directImageUrl))
            {
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;overflow:auto;background:transparent;">
                    <img src="@directImageUrl" alt="@resource.Title" style="max-width:100%;max-height:100%;object-fit:contain;" />
                </div>
            }
            else if (!string.IsNullOrEmpty(viewerUrl))
            {
                <iframe src="@viewerUrl" title="Document Viewer" allow="autoplay" referrerpolicy="no-referrer-when-downgrade" style="width:100%;height:100%;border:none;"></iframe>
            }
            else
            {
                <div class="ll-reader-no-preview">
                    <div style="@GetThumbnailGradient(resource.FileFormat); width:80px;height:100px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
                        <i class="bi @GetThumbnailIcon(resource.FileFormat)" style="font-size:3rem;color:white;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">@resource.Title.@resource.FileFormat.ToLower()</h5>
                    <p class="text-muted mb-3" style="max-width:400px;">This file format cannot be previewed in the browser.</p>
                    @if (allowDownloads)
                    {
                    <button class="ll-btn ll-btn-primary ll-detail-action-download" onclick="downloadResource(@resource.Id)" style="padding:10px 24px;">
                        <i class="bi bi-download me-2"></i>Download File
                    </button>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ── RIGHT SIDEBAR: Related Resources ── -->
    <div class="ll-reader-sidebar-right">
        @if (related.Any())
        {
            <h6>You might also like</h6>
            @foreach (var r in related)
            {
                int relPct = r.Rating > 0 ? (int)Math.Round((r.Rating / 5.0) * 100) : 0;
                <a href="@Url.Action("ResourceDetail", "Home", new { id = r.Id })" class="ll-reader-related-card">
                    <div class="ll-reader-related-thumb" style="@GetThumbnailGradient(r.FileFormat)">
                        <i class="bi @GetThumbnailIcon(r.FileFormat)"></i>
                        <span class="ll-repo-card-format">@r.FileFormat</span>
                    </div>
                    <div class="ll-reader-related-info">
                        <h6>@r.Title</h6>
                        @if (r.RatingCount > 0)
                        {
                            <div class="ll-reader-related-rating"><i class="bi bi-hand-thumbs-up-fill me-1"></i>@(relPct)% (@r.RatingCount)</div>
                        }
                        <div class="ll-reader-related-meta">@r.Uploader</div>
                    </div>
                </a>
            }
        }
        else
        {
            <h6>You might also like</h6>
            <p class="text-muted" style="font-size:0.8rem;">No related resources found yet.</p>
        }
    </div>
</div>

<!-- ═══════════ LESSONS LEARNED CTA ═══════════ -->
@if (!isPublicView && allowComments)
{
<div class="ll-reader-below" id="lessonsLearnedSection" style="margin-top:40px;padding:24px;">
    <div class="ll-scribd-panel text-center py-5">
        <div style="background:linear-gradient(135deg, #f59e0b, #d97706);width:80px;height:80px;border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;box-shadow:0 10px 15px -3px rgba(245,158,11,0.3);">
            <i class="bi bi-lightbulb" style="font-size:3.5rem;color:white;"></i>
        </div>
        <h4 class="fw-bold mb-3">Share Your Learnings</h4>
        <p class="text-muted mb-4 mx-auto" style="max-width:500px;">
            Did this resource help you understand a new concept or find a new teaching strategy? Share your insights with the community.
        </p>
        <button type="button" class="ll-btn ll-btn-primary" style="padding:12px 30px;font-size:1.05rem;" data-bs-toggle="modal" data-bs-target="#submitLessonModal">
            <i class="bi bi-plus-circle me-2"></i>Submit Lesson Learned
        </button>
    </div>
</div>
}

<!-- Submit Lesson Modal -->
@if (!isPublicView && allowComments)
{
<div class="modal fade" id="submitLessonModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="SubmitLesson" asp-controller="Home" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Submit a Lesson Learned</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="Category" value="General" />
                    <input type="hidden" name="ResourceId" value="@resource.Id" />
                    <div class="ll-form-group">
                        <label class="ll-form-label">Related Resource</label>
                        <input type="text" class="ll-form-control" value="@resource.Title" disabled>
                    </div>
                    <div class="ll-form-group">
                        <label class="ll-form-label">Title</label>
                        <input type="text" class="ll-form-control" name="Title" placeholder="Give your lesson a clear title" required>
                    </div>
                    <div class="ll-form-group">
                        <label class="ll-form-label">Your Insight</label>
                        <div id="rdLessonEditor" style="min-height: 120px;"></div>
                        <input type="hidden" name="Content" id="rdLessonContentHidden" />
                    </div>
                    <div class="ll-form-group">
                        <label class="ll-form-label">Tags</label>
                        <input type="text" class="ll-form-control" name="Tags" placeholder="Add tags separated by commas" value="General">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="ll-btn ll-btn-outline" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="ll-btn ll-btn-primary">
                        <i class="bi bi-send me-1"></i>Submit Lesson
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
}

@section Scripts {
<script>
    // ── Quill editor for Submit Lesson modal ──
    (function() {
        var rdLessonQuill = new Quill('#rdLessonEditor', {
            theme: 'snow',
            placeholder: 'Share what you learned, what worked well, any tips for others...',
            modules: { toolbar: [
                [{ 'header': [2, 3, false] }],
                ['bold', 'italic', 'underline'],
                [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                ['link'],
                ['clean']
            ]}
        });
        var lessonForm = document.getElementById('rdLessonEditor')?.closest('form');
        if (lessonForm) {
            lessonForm.addEventListener('submit', function() {
                var html = rdLessonQuill.root.innerHTML;
                document.getElementById('rdLessonContentHidden').value = html === '<p><br></p>' ? '' : html;
            });
        }
    })();

    // ── Description expand/collapse in left sidebar ──
    (function() {
        var desc = document.getElementById('readerDesc');
        var btn = document.getElementById('readerDescToggle');
        if (desc && btn) {
            setTimeout(function() {
                if (desc.scrollHeight > desc.clientHeight + 10) {
                    btn.style.display = 'inline-block';
                }
            }, 100);
        }
    })();

    function toggleReaderDesc() {
        var desc = document.getElementById('readerDesc');
        var btn = document.getElementById('readerDescToggle');
        if (!desc || !btn) return;
        desc.classList.toggle('ll-reader-desc-expanded');
        btn.textContent = desc.classList.contains('ll-reader-desc-expanded') ? 'Show less' : 'Full description';
    }
    // Like toggle
    async function toggleLike(btn, id) {
        if (btn.disabled) return;
        btn.disabled = true;

        const formData = new FormData();
        formData.append('id', id);

        try {
            const res = await fetch('@Url.Action("LikeResource", "Home")', { method: 'POST', body: formData });
            const data = await res.json();
            
            if (data.success) {
                var icon = btn.querySelector('i');
                var textSpan = btn.querySelectorAll('span')[0];
                var countEl = btn.querySelector('.ll-scribd-like-count') || btn.querySelector('.ll-reader-action-count');

                if (data.isLiked) {
                    btn.classList.add('active');
                    icon.className = 'bi bi-heart-fill';
                    textSpan.textContent = 'Liked';
                } else {
                    btn.classList.remove('active');
                    icon.className = 'bi bi-heart';
                    textSpan.textContent = 'Like';
                }
                if (countEl) countEl.textContent = data.count.toLocaleString();
            } else {
                alert('Action failed. Please make sure you are logged in.');
            }
        } catch(e) { /* ignored */ }
        btn.disabled = false;
    }

    // Star rating
    async function setRating(id, value) {
        var stars = document.querySelectorAll('.ll-reader-star');
        stars.forEach(s => s.style.pointerEvents = 'none');

        const formData = new FormData();
        formData.append('id', id);
        formData.append('rating', value);

        try {
            const res = await fetch('@Url.Action("RateResource", "Home")', { method: 'POST', body: formData });
            const data = await res.json();

            if (data.success) {
                stars.forEach(function(star, index) {
                    star.className = index < value
                        ? 'bi bi-star-fill ll-reader-star active'
                        : 'bi bi-star ll-reader-star';
                });

                var ratingScore = document.getElementById('ratingScore');
                if (!ratingScore) {
                    var summary = document.querySelector('.ll-reader-rating-summary');
                    if (summary) {
                        summary.innerHTML = '<span class="ll-reader-rating-score" id="ratingScore"></span><span class="ll-reader-rating-count" id="ratingStatsCount"></span>';
                        ratingScore = document.getElementById('ratingScore');
                    }
                }
                if (ratingScore) ratingScore.textContent = data.rating;
                var countEl = document.getElementById('ratingStatsCount');
                if (countEl) countEl.textContent = '(' + data.count + ' ratings)';
            } else {
                console.error('Failed to submit rating');
            }
        } catch(e) { /* ignored */ }
        stars.forEach(s => s.style.pointerEvents = 'auto');
    }

    // Download action
    function downloadResource(id) {
        var dlBtns = document.querySelectorAll('.ll-detail-action-download');
        dlBtns.forEach(function(btn) {
            btn._origHTML = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-clock"></i> <span>Starting...</span>';
            btn.disabled = true;
        });

        var downloadUrl = @Html.Raw(isPublicView ? "'/Home/PublicDownload'" : "'/Home/DownloadResource'");
        window.location.href = downloadUrl + '?id=' + id + '&inline=false';

        setTimeout(function() {
            dlBtns.forEach(function(btn) {
                btn.innerHTML = '<i class="bi bi-check-circle"></i> <span>Downloaded</span>';
                btn.disabled = false;
                setTimeout(function() { btn.innerHTML = btn._origHTML; }, 3000);
            });
        }, 1200);
    }

    // Save toggle
    async function toggleSave(btn, id) {
        if (btn.disabled) return;
        btn.disabled = true;

        const formData = new FormData();
        formData.append('id', id);

        try {
            const res = await fetch('@Url.Action("SaveResource", "Home")', { method: 'POST', body: formData });
            const data = await res.json();

            if (data.success) {
                var icon = btn.querySelector('i');
                var text = btn.querySelectorAll('span')[0];

                if (data.isSaved) {
                    btn.classList.add('active');
                    icon.className = 'bi bi-bookmark-fill';
                    text.textContent = 'Saved';
                } else {
                    btn.classList.remove('active');
                    icon.className = 'bi bi-bookmark';
                    text.textContent = 'Save';
                }
            } else {
                alert('Action failed. Please verify you are logged in.');
            }
        } catch(e) { /* ignored */ }
        btn.disabled = false;
    }

    // Mark as complete
    async function markComplete(id) {
        const btn = document.getElementById('markCompleteBtn');
        if (btn.disabled) return;
        btn.disabled = true;

        const formData = new FormData();
        formData.append('id', id);

        try {
            const res = await fetch('@Url.Action("MarkComplete", "Home")', { method: 'POST', body: formData });
            const data = await res.json();
            if (data.success) {
                var icon = btn.querySelector('i');
                var text = btn.querySelectorAll('span')[0];
                btn.classList.add('active');
                icon.className = 'bi bi-check-circle-fill';
                text.textContent = 'Completed';
            }
        } catch(e) { /* ignored */ }
        btn.disabled = false;
    }

    // ── Time-based reading progress tracking ──
    (function() {
        var resourceId = @(resource.Id);
        var startProgress = @(ViewBag.CurrentProgress ?? 10);
        var isCompleted = @((ViewBag.IsCompleted ?? false).ToString().ToLower());
        if (isCompleted) return;

        var secondsOnPage = 0;
        var lastReported = startProgress;
        // Estimated reading time: 5 minutes = 100% (adjustable)
        var totalSecondsFor100 = 300;

        var progressTimer = setInterval(function() {
            if (document.hidden) return;
            secondsOnPage++;
            // Calculate progress based on time spent (starting from current progress)
            var timeProgress = Math.min(95, Math.round((secondsOnPage / totalSecondsFor100) * 100) + startProgress);
            if (timeProgress > lastReported && (timeProgress - lastReported) >= 5) {
                lastReported = timeProgress;
                var formData = new FormData();
                formData.append('id', resourceId);
                formData.append('progress', timeProgress);
                fetch('@Url.Action("UpdateReadingProgress", "Home")', { method: 'POST', body: formData }).catch(function(){});
            }
        }, 1000);

        window.addEventListener('beforeunload', function() {
            clearInterval(progressTimer);
        });
    })();


</script>
}
