@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Resource Detail";
    ViewData["ActivePage"] = "Repository";

    var resource = ViewBag.Resource as LearnLink.Models.ResourceViewModel;
    if (resource == null) return;
    var related = ViewBag.RelatedResources as List<LearnLink.Models.ResourceViewModel> ?? new List<LearnLink.Models.ResourceViewModel>();
    var fileUrl = ViewBag.FileUrl as string ?? string.Empty;
    var canPreview = (bool?)(ViewBag.CanPreview ?? false) ?? false;
    var allowDownloads = (bool?)(ViewBag.AllowDownloads ?? true) ?? true;
    var allowComments = (bool?)(ViewBag.AllowComments ?? true) ?? true;
    var isPublicView = (bool?)(ViewBag.IsPublicView ?? false) ?? false;

    string Normal(string f) => f?.TrimStart('.').ToUpper() ?? "";

    string GetThumbnailGradient(string format) => Normal(format) switch
    {
        "PDF" => "background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%)",
        "DOCX" or "DOC" => "background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)",
        "PPTX" or "PPT" => "background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%)",
        "XLSX" or "XLS" => "background: linear-gradient(135deg, #10b981 0%, #059669 100%)",
        _ => "background: linear-gradient(135deg, #8b5cf6) 0%, #7c3aed 100%)"
    };

    string GetThumbnailIcon(string format) => Normal(format) switch
    {
        "PDF" => "bi-file-earmark-pdf",
        "DOCX" or "DOC" => "bi-file-earmark-word",
        "PPTX" or "PPT" => "bi-file-earmark-ppt",
        "XLSX" or "XLS" => "bi-file-earmark-excel",
        _ => "bi-file-earmark"
    };

    string GetFormatLabel(string format) => Normal(format) switch
    {
        "PDF" => "PDF Document",
        "DOCX" or "DOC" => "Word Document",
        "PPTX" or "PPT" => "PowerPoint Presentation",
        "XLSX" or "XLS" => "Excel Spreadsheet",
        _ => "Document"
    };
}

@{
    var fmt = Normal(resource.FileFormat);
    var isOffice = fmt == "DOCX" || fmt == "DOC" || fmt == "PPTX" || fmt == "PPT" || fmt == "XLSX" || fmt == "XLS";
    var hasFile = canPreview && !string.IsNullOrWhiteSpace(fileUrl);
    var isDriveFile = !string.IsNullOrEmpty(ViewBag.DriveFileId as string);
    var drivePreviewUrl = ViewBag.DrivePreviewUrl as string ?? "";
    var canUseGoogleViewer = fileUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase);
    var previewAction = isPublicView ? "PublicDownload" : "DownloadResource";

    string viewerUrl = "";
    if (hasFile)
    {
        if (isDriveFile)
        {
            // Use Drive's own preview embed for all formats
            viewerUrl = drivePreviewUrl;
        }
        else if (fmt == "PDF")
        {
            viewerUrl = Url.Action(previewAction, "Home", new { id = resource.Id, inline = true }) + "#view=FitH";
        }
        else if (isOffice && canUseGoogleViewer)
        {
            viewerUrl = "https://docs.google.com/gview?url=" + Uri.EscapeDataString(fileUrl) + "&embedded=true";
        }
        else
        {
            viewerUrl = Url.Action(previewAction, "Home", new { id = resource.Id, inline = true }) ?? "";
        }
    }

    // "Read Now" should open the viewer in a new tab, not download
    string readNowUrl = "";
    if (hasFile)
    {
        if (isDriveFile)
        {
            readNowUrl = drivePreviewUrl;
        }
        else if (isOffice && canUseGoogleViewer)
        {
            readNowUrl = "https://docs.google.com/gview?url=" + Uri.EscapeDataString(fileUrl) + "&embedded=true";
        }
        else
        {
            readNowUrl = Url.Action(previewAction, "Home", new { id = resource.Id, inline = true }) ?? "";
        }
    }
}


@if (TempData["ErrorMessage"] != null)
{
<div class="alert alert-warning alert-dismissible fade show mt-2" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    @TempData["ErrorMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}

<!-- ═══════════ SCRIBD-STYLE READER LAYOUT ═══════════ -->
<div class="ll-reader-layout">
    <!-- ── LEFT SIDEBAR: Metadata ── -->
    <div class="ll-reader-sidebar-left">
        <!-- Stats -->
        <div class="ll-reader-meta-stats">
            @{
                int ratingPct = resource.Rating > 0 ? (int)Math.Round((resource.Rating / 5.0) * 100) : 0;
            }
            @if (resource.RatingCount > 0)
            {
                <span><i class="bi bi-hand-thumbs-up-fill"></i> @(ratingPct)% (@resource.RatingCount)</span>
                <span>&middot;</span>
            }
            <span>@resource.ViewCount.ToString("N0") views</span>
            <span>&middot;</span>
            <span>@GetFormatLabel(resource.FileFormat)</span>
        </div>

        <!-- Title -->
        <h1 class="ll-reader-meta-title">@resource.Title</h1>

        <!-- Description -->
        <div class="ll-reader-meta-desc" id="readerDesc">
            @Html.Raw(resource.Description)
        </div>
        <button class="ll-reader-desc-toggle" id="readerDescToggle" onclick="toggleReaderDesc()" style="display:none;">Full description</button>

        <!-- Uploader -->
        <div class="ll-reader-meta-uploader">
            Uploaded by <strong>@resource.Uploader</strong> on @resource.CreatedAt.ToString("MMM dd, yyyy")
        </div>

        <hr class="ll-reader-meta-divider" />

        <!-- Tags -->
        <div class="ll-scribd-tags" style="margin-bottom:14px;">
            <a class="ll-scribd-tag ll-scribd-tag-link" href="@Url.Action("Tag", "Home", new { tag = resource.Subject })">@resource.Subject</a>
            <span class="ll-scribd-tag">@resource.GradeLevel</span>
            @if (!string.IsNullOrEmpty(resource.Quarter))
            {
                <span class="ll-scribd-tag">@resource.Quarter</span>
            }
            <span class="ll-scribd-tag">@resource.ResourceType</span>
            @foreach (var cat in resource.Categories)
            {
                <span class="ll-scribd-tag ll-scribd-tag-cat"><i class="bi bi-folder me-1"></i>@cat</span>
            }
            @foreach (var tag in resource.Tags)
            {
                <a class="ll-scribd-tag ll-scribd-tag-hash ll-scribd-tag-link" href="@Url.Action("Tag", "Home", new { tag })"><i class="bi bi-hash"></i>@tag</a>
            }
        </div>

        <hr class="ll-reader-meta-divider" />

        <!-- Action Buttons Grid -->
        <div class="ll-reader-action-grid">
            @if (allowDownloads)
            {
            <button class="ll-reader-action-btn ll-detail-action-download" onclick="downloadResource(@resource.Id)">
                <i class="bi bi-download"></i>
                Download
            </button>
            }
            @if (!isPublicView)
            {
            <button class="ll-reader-action-btn @(resource.IsSaved ? "active" : "")" id="saveBtn" onclick="toggleSave(this, @resource.Id)">
                <i class="bi @(resource.IsSaved ? "bi-bookmark-fill" : "bi-bookmark")"></i>
                <span>@(resource.IsSaved ? "Saved" : "Save")</span>
            </button>
            }
            @if (!isPublicView)
            {
            <button class="ll-reader-action-btn @(resource.IsLiked ? "active" : "")" id="likeBtn" onclick="toggleLike(this, @resource.Id)">
                <i class="bi @(resource.IsLiked ? "bi-heart-fill" : "bi-heart")"></i>
                <span>@(resource.IsLiked ? "Liked" : "Like")</span>
            </button>
            }
            @if (!isPublicView)
            {
            <button class="ll-reader-action-btn" onclick="document.getElementById('commentsSection').scrollIntoView({behavior:'smooth'})">
                <i class="bi bi-chat-dots"></i>
                <span>Comments</span>
            </button>
            }
        </div>

        <!-- Rating Widget -->
        @if (!isPublicView)
        {
        <div class="ll-scribd-rating-widget" id="ratingWidget" style="margin-top:28px;">
            <span class="ll-scribd-rating-label">Rate this resource</span>
            <div class="ll-reader-stars">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="bi bi-star ll-reader-star" data-value="@i" onclick="setRating(@resource.Id, @i)"></i>
                }
            </div>
            @if (resource.Rating > 0)
            {
                <span class="ll-scribd-rating-info">
                    <span id="ratingScore">@resource.Rating.ToString("0.0")</span>/5
                    <span class="text-muted" id="ratingStatsCount">(@resource.RatingCount ratings)</span>
                </span>
            }
            else
            {
                <span class="ll-scribd-rating-info text-muted" id="ratingStatsCount">No ratings yet</span>
            }
        </div>
        }

        <!-- File Info -->
        <div class="ll-scribd-file-info" style="margin-top:14px;">
            <div class="ll-scribd-file-row"><span>Format</span><span>@GetFormatLabel(resource.FileFormat)</span></div>
            <div class="ll-scribd-file-row"><span>File Size</span><span>@resource.FileSize</span></div>
            <div class="ll-scribd-file-row"><span>Subject</span><span>@resource.Subject</span></div>
            <div class="ll-scribd-file-row"><span>Grade Level</span><span>@resource.GradeLevel</span></div>
            <div class="ll-scribd-file-row"><span>Type</span><span>@resource.ResourceType</span></div>
            @if (!string.IsNullOrEmpty(resource.Quarter))
            {
            <div class="ll-scribd-file-row"><span>Quarter</span><span>@resource.Quarter</span></div>
            }
            <div class="ll-scribd-file-row"><span>Uploaded</span><span>@resource.CreatedAt.ToString("MMM dd, yyyy")</span></div>
        </div>

        <!-- Version History -->
        @if (ViewBag.ResourceVersions != null)
        {
            var versions = ViewBag.ResourceVersions as IEnumerable<LearnLink.Models.ResourceVersion>;
            if (versions != null && versions.Any())
            {
                <details class="ll-scribd-versions" style="margin-top:14px;">
                    <summary><i class="bi bi-clock-history me-2"></i>Version History (@versions.Count())</summary>
                    <div class="ll-scribd-versions-list">
                        @foreach (var v in versions)
                        {
                            <div class="ll-scribd-version-item">
                                <div class="d-flex justify-content-between">
                                    <strong style="color:var(--ll-primary);font-size:0.85rem;">@v.VersionNumber</strong>
                                    <span class="text-muted" style="font-size:0.8rem;">@v.DateUpdated.ToString("MMM dd, yyyy")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(v.VersionNotes))
                                {
                                    <div class="small bg-light p-2 rounded mt-1" style="border-left:3px solid var(--ll-primary);font-size:0.78rem;">@v.VersionNotes</div>
                                }
                                <div class="small text-muted mt-1"><i class="bi @GetThumbnailIcon(v.FileFormat)"></i> @v.FileFormat.ToUpper() · @v.FileSize</div>
                            </div>
                        }
                    </div>
                </details>
            }
        }

        @if (isPublicView)
        {
        <div style="margin-top:20px;">
            <a href="@Url.Action("Register", "Home")" class="ll-btn ll-btn-primary w-100" style="text-decoration:none;justify-content:center;">
                <i class="bi bi-person-plus me-2"></i>Sign up for full access
            </a>
        </div>
        }
    </div>

    <!-- ── CENTER: Document Viewer ── -->
    <div class="ll-reader-main">
        <!-- Toolbar -->
        <div class="ll-reader-toolbar">
            <div class="ll-reader-toolbar-left">
                <div class="ll-reader-toolbar-icon" style="@GetThumbnailGradient(resource.FileFormat)">
                    <i class="bi @GetThumbnailIcon(resource.FileFormat)"></i>
                </div>
                <div>
                    <div class="ll-reader-toolbar-title">@resource.Title</div>
                    <div class="ll-reader-toolbar-sub">@resource.FileSize · @resource.FileFormat.ToUpper()</div>
                </div>
            </div>
            <div class="ll-reader-toolbar-actions">
                @if (allowDownloads)
                {
                <button class="ll-detail-action-download" onclick="downloadResource(@resource.Id)" title="Download">
                    <i class="bi bi-download"></i>
                </button>
                }
                <a href="@Url.Action("Repository", "Home")" title="Back to Repository">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>

        <!-- Viewer Frame -->
        <div class="ll-reader-viewer-frame">
            @if (!hasFile)
            {
                <div class="ll-reader-no-preview">
                    <i class="bi bi-cloud-slash"></i>
                    <p>No file has been attached to this resource yet.</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(viewerUrl))
            {
                <iframe src="@viewerUrl" title="Document Viewer" allow="autoplay"></iframe>
            }
            else
            {
                <div class="ll-reader-no-preview">
                    <div style="@GetThumbnailGradient(resource.FileFormat); width:80px;height:100px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
                        <i class="bi @GetThumbnailIcon(resource.FileFormat)" style="font-size:3rem;color:white;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">@resource.Title.@resource.FileFormat.ToLower()</h5>
                    <p class="text-muted mb-3" style="max-width:400px;">This file format cannot be previewed in the browser.</p>
                    @if (allowDownloads)
                    {
                    <button class="ll-btn ll-btn-primary ll-detail-action-download" onclick="downloadResource(@resource.Id)" style="padding:10px 24px;">
                        <i class="bi bi-download me-2"></i>Download File
                    </button>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ── RIGHT SIDEBAR: Related Resources ── -->
    <div class="ll-reader-sidebar-right">
        @if (related.Any())
        {
            <h6>You might also like</h6>
            @foreach (var r in related)
            {
                int relPct = r.Rating > 0 ? (int)Math.Round((r.Rating / 5.0) * 100) : 0;
                <a href="@Url.Action("ResourceDetail", "Home", new { id = r.Id })" class="ll-reader-related-card">
                    <div class="ll-reader-related-thumb" style="@GetThumbnailGradient(r.FileFormat)">
                        <i class="bi @GetThumbnailIcon(r.FileFormat)"></i>
                        <span class="ll-repo-card-format">@r.FileFormat</span>
                    </div>
                    <div class="ll-reader-related-info">
                        <h6>@r.Title</h6>
                        @if (r.RatingCount > 0)
                        {
                            <div class="ll-reader-related-rating"><i class="bi bi-hand-thumbs-up-fill me-1"></i>@(relPct)% (@r.RatingCount)</div>
                        }
                        <div class="ll-reader-related-meta">@r.Uploader</div>
                    </div>
                </a>
            }
        }
        else
        {
            <h6>You might also like</h6>
            <p class="text-muted" style="font-size:0.8rem;">No related resources found yet.</p>
        }
    </div>
</div>

<!-- ═══════════ COMMENTS (below the reader layout) ═══════════ -->
<div class="ll-reader-below" id="commentsSection" style="margin-top:40px;padding:24px;">
    @if (ViewBag.AllowComments == true)
    {
        var comments = ViewBag.Comments as List<LearnLink.Models.ResourceComment> ?? new List<LearnLink.Models.ResourceComment>();
        <div class="ll-scribd-panel">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="ll-scribd-panel-title mb-0"><i class="bi bi-chat-dots me-2"></i>Comments (<span id="commentCount">@comments.Count</span>)</h6>
                <div style="display:flex;gap:8px;">
                    <button type="button" class="btn btn-sm active" onclick="sortComments('recent')" id="sortRecent" style="border:1px solid #cbd5e1;background:#fff;color:#1e293b;font-weight:500;padding:6px 12px;border-radius:6px;">
                        <i class="bi bi-clock me-1"></i>Recent
                    </button>
                    <button type="button" class="btn btn-sm" onclick="sortComments('liked')" id="sortLiked" style="border:1px solid #cbd5e1;background:#fff;color:#1e293b;font-weight:500;padding:6px 12px;border-radius:6px;">
                        <i class="bi bi-hand-thumbs-up me-1"></i>Most Liked
                    </button>
                </div>
            </div>
            @if (!isPublicView)
            {
            <div class="d-flex gap-3 mb-6" style="padding-bottom: 32px; border-bottom: 1px solid #e2e8f0;">
                <div>
                    <div class="ll-avatar" style="width:40px;height:40px;font-size:0.8rem;background:linear-gradient(135deg, var(--ll-primary), var(--ll-primary-dark));flex-shrink:0;">
                        @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?")
                    </div>
                </div>
                <div class="flex-grow-1">
                    <textarea class="ll-form-control" id="commentInput" rows="3" placeholder="Write a comment..." maxlength="2000" style="resize:vertical;font-size:0.95rem;"></textarea>
                    <div class="d-flex justify-content-end mt-3">
                        <button class="ll-btn ll-btn-primary btn-sm" onclick="postComment(@resource.Id)" id="postCommentBtn">
                            <i class="bi bi-send me-1"></i>Post Comment
                        </button>
                    </div>
                </div>
            </div>
            }
            <div id="commentsList">
                @if (!comments.Any())
                {
                    <div class="text-center py-4 text-muted" id="noCommentsMsg">
                        <i class="bi bi-chat-square-text" style="font-size:2rem;"></i>
                        <p class="mt-2 mb-0">No comments yet. Be the first to share your thoughts!</p>
                    </div>
                }
                @foreach (var comment in comments)
                {
                    <div class="d-flex gap-3 mb-5 comment-item" data-comment-id="@comment.CommentId" style="padding-bottom:28px;border-bottom:1px solid #e2e8f0;">
                        <div>
                            <div class="ll-avatar" style="width:40px;height:40px;font-size:0.8rem;@(comment.User?.AvatarColor ?? "background:linear-gradient(135deg, var(--ll-primary), var(--ll-primary-dark))");flex-shrink:0;">
                                @(comment.User?.Initials ?? "?")
                            </div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <strong style="font-size:0.95rem;">@(comment.User?.FullName ?? "Unknown")</strong>
                                    <span class="text-muted ms-2" style="font-size:0.85rem;">@comment.DatePosted.ToString("MMM dd, yyyy h:mm tt")</span>
                                </div>
                                <div class="btn-group btn-group-sm">
                                    @if (comment.UserId == (string)ViewBag.CurrentUserId || User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
                                    {
                                        <button class="btn btn-sm text-muted p-0" onclick="showEditBox(@comment.CommentId)" title="Edit comment">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm text-muted p-0" onclick="deleteComment(@comment.CommentId)" title="Delete comment">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                            <div id="commentContent_@comment.CommentId" class="comment-display">
                                <p class="mb-2 mt-2" style="font-size:0.95rem;line-height:1.6;">@comment.Content</p>
                                @if (comment.DateUpdated.HasValue && comment.DateUpdated > comment.DatePosted)
                                {
                                    <span class="text-muted small" style="font-style:italic;"><i class="bi bi-pencil-square me-1"></i>Edited</span>
                                }
                            </div>
                            <div id="editBox_@comment.CommentId" class="edit-box d-none" style="margin-top:12px;">
                                <textarea class="ll-form-control" id="editInput_@comment.CommentId" rows="3" maxlength="2000" style="resize:vertical;font-size:0.95rem;"></textarea>
                                <div class="d-flex justify-content-end gap-2 mt-2">
                                    <button class="btn btn-sm text-muted" onclick="hideEditBox(@comment.CommentId)">Cancel</button>
                                    <button class="ll-btn ll-btn-primary btn-sm" onclick="saveCommentEdit(@resource.Id, @comment.CommentId)" style="font-size:0.9rem;"><i class="bi bi-check me-1"></i>Save</button>
                                </div>
                            </div>
                            <div style="display:flex;gap:16px;margin-top:12px;">
                                @if (!isPublicView)
                                {
                                <button class="btn btn-sm text-muted p-0" style="font-size:0.85rem;" onclick="toggleCommentLike(this, @comment.CommentId)" data-liked="false">
                                    <i class="bi bi-heart me-1"></i><span class="like-count">0</span>
                                </button>
                                <button class="btn btn-sm text-muted p-0" style="font-size:0.85rem;" onclick="showReplyBox(@comment.CommentId)">
                                    <i class="bi bi-reply me-1"></i>Reply
                                </button>
                                }
                            </div>

                            <div class="mt-2 d-none" id="replyBox_@comment.CommentId">
                                <textarea class="ll-form-control" rows="2" id="replyInput_@comment.CommentId" placeholder="Write a reply..." maxlength="2000" style="resize:vertical;font-size:0.85rem;"></textarea>
                                <div class="d-flex justify-content-end gap-2 mt-1">
                                    <button class="btn btn-sm text-muted" onclick="hideReplyBox(@comment.CommentId)">Cancel</button>
                                    <button class="ll-btn ll-btn-primary btn-sm" onclick="postReply(@resource.Id, @comment.CommentId)" style="font-size:0.8rem;">Reply</button>
                                </div>
                            </div>

                            @if (comment.Replies != null && comment.Replies.Any())
                            {
                                <div class="mt-2 ms-3 border-start ps-3" id="replies_@comment.CommentId">
                                    @foreach (var reply in comment.Replies.OrderBy(r => r.DatePosted))
                                    {
                                        <div class="d-flex gap-2 mb-2 comment-item" data-comment-id="@reply.CommentId">
                                            <div>
                                                <div class="ll-avatar" style="width:28px;height:28px;font-size:0.7rem;@(reply.User?.AvatarColor ?? "background:linear-gradient(135deg, var(--ll-primary), var(--ll-primary-dark))")">
                                                    @(reply.User?.Initials ?? "?")
                                                </div>
                                            </div>
                                            <div class="flex-grow-1">
                                                <div class="d-flex justify-content-between">
                                                    <div>
                                                        <strong style="font-size:0.85rem;">@(reply.User?.FullName ?? "Unknown")</strong>
                                                        <span class="text-muted ms-2" style="font-size:0.75rem;">@reply.DatePosted.ToString("MMM dd, yyyy h:mm tt")</span>
                                                    </div>
                                                    @if (reply.UserId == (string)ViewBag.CurrentUserId || User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
                                                    {
                                                        <button class="btn btn-sm text-muted p-0" onclick="deleteComment(@reply.CommentId)" title="Delete reply">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    }
                                                </div>
                                                <p class="mb-0 mt-1" style="font-size:0.85rem;">@reply.Content</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="mt-2 ms-3 border-start ps-3 d-none" id="replies_@comment.CommentId"></div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="ll-scribd-panel text-center py-4 text-muted">
            <i class="bi bi-chat-square-text" style="font-size:2rem;opacity:0.3;"></i>
            <p class="mt-2 mb-0">Comments and ratings are disabled for this resource.</p>
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteCommentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border:none;border-radius:12px;box-shadow:0 20px 25px -5px rgba(0,0,0,0.1);">
            <div class="modal-body text-center" style="padding:40px 24px;">
                <i class="bi bi-exclamation-circle" style="font-size:3rem;color:#ef4444;display:block;margin-bottom:16px;"></i>
                <h5 class="modal-title" style="margin-bottom:8px;font-weight:600;color:#1e293b;">Delete Comment?</h5>
                <p class="text-muted mb-0" style="font-size:0.95rem;">This action cannot be undone. Are you sure you want to delete this comment?</p>
            </div>
            <div class="modal-footer" style="padding:16px 24px;border-top:1px solid #e2e8f0;display:flex;gap:8px;justify-content:center;">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal" style="border:1px solid #cbd5e1;color:#64748b;font-weight:500;">
                    <i class="bi bi-x me-1"></i>Cancel
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn" style="font-weight:500;">
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Description expand/collapse in left sidebar ──
    (function() {
        var desc = document.getElementById('readerDesc');
        var btn = document.getElementById('readerDescToggle');
        if (desc && btn) {
            setTimeout(function() {
                if (desc.scrollHeight > desc.clientHeight + 10) {
                    btn.style.display = 'inline-block';
                }
            }, 100);
        }
    })();

    function toggleReaderDesc() {
        var desc = document.getElementById('readerDesc');
        var btn = document.getElementById('readerDescToggle');
        if (!desc || !btn) return;
        desc.classList.toggle('ll-reader-desc-expanded');
        btn.textContent = desc.classList.contains('ll-reader-desc-expanded') ? 'Show less' : 'Full description';
    }
    // Like toggle
    async function toggleLike(btn, id) {
        if (btn.disabled) return;
        btn.disabled = true;

        const formData = new FormData();
        formData.append('id', id);

        try {
            const res = await fetch('@Url.Action("LikeResource", "Home")', { method: 'POST', body: formData });
            const data = await res.json();
            
            if (data.success) {
                var icon = btn.querySelector('i');
                var textSpan = btn.querySelectorAll('span')[0];
                var countEl = btn.querySelector('.ll-scribd-like-count') || btn.querySelector('.ll-reader-action-count');

                if (data.isLiked) {
                    btn.classList.add('active');
                    icon.className = 'bi bi-heart-fill';
                    textSpan.textContent = 'Liked';
                } else {
                    btn.classList.remove('active');
                    icon.className = 'bi bi-heart';
                    textSpan.textContent = 'Like';
                }
                if (countEl) countEl.textContent = data.count.toLocaleString();
            } else {
                alert('Action failed. Please make sure you are logged in.');
            }
        } catch(e) { /* ignored */ }
        btn.disabled = false;
    }

    // Star rating
    async function setRating(id, value) {
        var stars = document.querySelectorAll('.ll-reader-star');
        stars.forEach(s => s.style.pointerEvents = 'none');

        const formData = new FormData();
        formData.append('id', id);
        formData.append('rating', value);

        try {
            const res = await fetch('@Url.Action("RateResource", "Home")', { method: 'POST', body: formData });
            const data = await res.json();

            if (data.success) {
                stars.forEach(function(star, index) {
                    star.className = index < value
                        ? 'bi bi-star-fill ll-reader-star active'
                        : 'bi bi-star ll-reader-star';
                });

                var ratingScore = document.getElementById('ratingScore');
                if (!ratingScore) {
                    var summary = document.querySelector('.ll-reader-rating-summary');
                    if (summary) {
                        summary.innerHTML = '<span class="ll-reader-rating-score" id="ratingScore"></span><span class="ll-reader-rating-count" id="ratingStatsCount"></span>';
                        ratingScore = document.getElementById('ratingScore');
                    }
                }
                if (ratingScore) ratingScore.textContent = data.rating;
                var countEl = document.getElementById('ratingStatsCount');
                if (countEl) countEl.textContent = '(' + data.count + ' ratings)';
            } else {
                console.error('Failed to submit rating');
            }
        } catch(e) { /* ignored */ }
        stars.forEach(s => s.style.pointerEvents = 'auto');
    }

    // Download action
    function downloadResource(id) {
        var dlBtns = document.querySelectorAll('.ll-detail-action-download');
        dlBtns.forEach(function(btn) {
            btn._origHTML = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-clock"></i> <span>Starting...</span>';
            btn.disabled = true;
        });

        var downloadUrl = @Html.Raw(isPublicView ? "'/Home/PublicDownload'" : "'/Home/DownloadResource'");
        window.location.href = downloadUrl + '?id=' + id + '&inline=false';

        setTimeout(function() {
            dlBtns.forEach(function(btn) {
                btn.innerHTML = '<i class="bi bi-check-circle"></i> <span>Downloaded</span>';
                btn.disabled = false;
                setTimeout(function() { btn.innerHTML = btn._origHTML; }, 3000);
            });
        }, 1200);
    }

    // Save toggle
    async function toggleSave(btn, id) {
        if (btn.disabled) return;
        btn.disabled = true;

        const formData = new FormData();
        formData.append('id', id);

        try {
            const res = await fetch('@Url.Action("SaveResource", "Home")', { method: 'POST', body: formData });
            const data = await res.json();

            if (data.success) {
                var icon = btn.querySelector('i');
                var text = btn.querySelectorAll('span')[0];

                if (data.isSaved) {
                    btn.classList.add('active');
                    icon.className = 'bi bi-bookmark-fill';
                    text.textContent = 'Saved';
                } else {
                    btn.classList.remove('active');
                    icon.className = 'bi bi-bookmark';
                    text.textContent = 'Save';
                }
            } else {
                alert('Action failed. Please verify you are logged in.');
            }
        } catch(e) { /* ignored */ }
        btn.disabled = false;
    }

    // Mark as complete
    async function markComplete(id) {
        const btn = document.getElementById('markCompleteBtn');
        if (btn.disabled) return;
        btn.disabled = true;

        const formData = new FormData();
        formData.append('id', id);

        try {
            const res = await fetch('@Url.Action("MarkComplete", "Home")', { method: 'POST', body: formData });
            const data = await res.json();
            if (data.success) {
                var icon = btn.querySelector('i');
                var text = btn.querySelectorAll('span')[0];
                btn.classList.add('active');
                icon.className = 'bi bi-check-circle-fill';
                text.textContent = 'Completed';
            }
        } catch(e) { /* ignored */ }
        btn.disabled = false;
    }

    // ====== Comments ======
    async function postComment(resourceId) {
        const input = document.getElementById('commentInput');
        const content = input.value.trim();
        if (!content) return;

        const btn = document.getElementById('postCommentBtn');
        btn.disabled = true;

        try {
            const res = await fetch('@Url.Action("PostComment", "Home")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `resourceId=${resourceId}&content=${encodeURIComponent(content)}`
            });
            const data = await res.json();
            if (data.success) {
                input.value = '';
                const noMsg = document.getElementById('noCommentsMsg');
                if (noMsg) noMsg.remove();

                const html = `
                    <div class="d-flex gap-3 mb-3 comment-item" data-comment-id="${data.comment.commentId}">
                        <div>
                            <div class="ll-avatar" style="width:36px;height:36px;font-size:0.8rem;${data.comment.authorColor || 'background:linear-gradient(135deg, var(--ll-primary), var(--ll-primary-dark))'}">
                                ${data.comment.authorInitials}
                            </div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <strong style="font-size:0.9rem;">${data.comment.authorName}</strong>
                                    <span class="text-muted ms-2" style="font-size:0.8rem;">${data.comment.datePosted}</span>
                                </div>
                                <button class="btn btn-sm text-muted p-0" onclick="deleteComment(${data.comment.commentId})" title="Delete comment">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                            <p class="mb-1 mt-1" style="font-size:0.9rem;">${data.comment.content}</p>
                            <button class="btn btn-sm text-muted p-0" style="font-size:0.8rem;" onclick="showReplyBox(${data.comment.commentId})">
                                <i class="bi bi-reply me-1"></i>Reply
                            </button>
                            <div class="mt-2 d-none" id="replyBox_${data.comment.commentId}">
                                <textarea class="ll-form-control" rows="2" id="replyInput_${data.comment.commentId}" placeholder="Write a reply..." maxlength="2000" style="resize:vertical;font-size:0.85rem;"></textarea>
                                <div class="d-flex justify-content-end gap-2 mt-1">
                                    <button class="btn btn-sm text-muted" onclick="hideReplyBox(${data.comment.commentId})">Cancel</button>
                                    <button class="ll-btn ll-btn-primary btn-sm" onclick="postReply(${resourceId}, ${data.comment.commentId})" style="font-size:0.8rem;">Reply</button>
                                </div>
                            </div>
                            <div class="mt-2 ms-3 border-start ps-3 d-none" id="replies_${data.comment.commentId}"></div>
                        </div>
                    </div>`;
                document.getElementById('commentsList').insertAdjacentHTML('afterbegin', html);
                
                // Update comment count
                const countSpan = document.getElementById('commentCount');
                if (countSpan) {
                    const currentCount = parseInt(countSpan.textContent) || 0;
                    countSpan.textContent = currentCount + 1;
                }
            }
        } catch(e) { console.error(e); }
        btn.disabled = false;
    }

    function showReplyBox(commentId) {
        document.getElementById('replyBox_' + commentId).classList.remove('d-none');
    }

    function hideReplyBox(commentId) {
        document.getElementById('replyBox_' + commentId).classList.add('d-none');
    }

    async function postReply(resourceId, parentCommentId) {
        const input = document.getElementById('replyInput_' + parentCommentId);
        const content = input.value.trim();
        if (!content) return;

        try {
            const res = await fetch('@Url.Action("PostComment", "Home")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `resourceId=${resourceId}&content=${encodeURIComponent(content)}&parentCommentId=${parentCommentId}`
            });
            const data = await res.json();
            if (data.success) {
                input.value = '';
                hideReplyBox(parentCommentId);

                const repliesDiv = document.getElementById('replies_' + parentCommentId);
                repliesDiv.classList.remove('d-none');

                const html = `
                    <div class="d-flex gap-2 mb-2 comment-item" data-comment-id="${data.comment.commentId}">
                        <div>
                            <div class="ll-avatar" style="width:28px;height:28px;font-size:0.7rem;${data.comment.authorColor || 'background:linear-gradient(135deg, var(--ll-primary), var(--ll-primary-dark))'}">
                                ${data.comment.authorInitials}
                            </div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <strong style="font-size:0.85rem;">${data.comment.authorName}</strong>
                                    <span class="text-muted ms-2" style="font-size:0.75rem;">${data.comment.datePosted}</span>
                                </div>
                                <button class="btn btn-sm text-muted p-0" onclick="deleteComment(${data.comment.commentId})" title="Delete reply">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                            <p class="mb-0 mt-1" style="font-size:0.85rem;">${data.comment.content}</p>
                        </div>
                    </div>`;
                repliesDiv.insertAdjacentHTML('beforeend', html);
            }
        } catch(e) { /* ignored */ }
    }

    let pendingDeleteCommentId = null;

    function deleteComment(commentId) {
        pendingDeleteCommentId = commentId;
        const deleteModal = new bootstrap.Modal(document.getElementById('deleteCommentModal'));
        deleteModal.show();
    }

    async function confirmDeleteComment() {
        const commentId = pendingDeleteCommentId;
        if (!commentId) return;

        try {
            const res = await fetch('@Url.Action("DeleteComment", "Home")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `commentId=${commentId}`
            });
            const data = await res.json();
            if (data.success) {
                const el = document.querySelector(`[data-comment-id="${commentId}"]`);
                if (el) el.remove();
                const modal = bootstrap.Modal.getInstance(document.getElementById('deleteCommentModal'));
                modal.hide();
                pendingDeleteCommentId = null;
                
                // Update comment count
                const countSpan = document.getElementById('commentCount');
                if (countSpan) {
                    const currentCount = parseInt(countSpan.textContent) || 0;
                    countSpan.textContent = Math.max(0, currentCount - 1);
                }
            }
        } catch(e) { console.error(e); }
    }

    // Edit comment functions
    function showEditBox(commentId) {
        const display = document.getElementById('commentContent_' + commentId);
        const editBox = document.getElementById('editBox_' + commentId);
        const textarea = document.getElementById('editInput_' + commentId);
        if (display && editBox) {
            const content = display.querySelector('p').textContent;
            textarea.value = content;
            display.classList.add('d-none');
            editBox.classList.remove('d-none');
            textarea.focus();
        }
    }

    function hideEditBox(commentId) {
        const display = document.getElementById('commentContent_' + commentId);
        const editBox = document.getElementById('editBox_' + commentId);
        if (display && editBox) {
            display.classList.remove('d-none');
            editBox.classList.add('d-none');
        }
    }

    async function saveCommentEdit(resourceId, commentId) {
        const textarea = document.getElementById('editInput_' + commentId);
        const content = textarea.value.trim();
        if (!content) {
            alert('Comment cannot be empty');
            return;
        }

        try {
            const res = await fetch('@Url.Action("UpdateComment", "Home")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `resourceId=${resourceId}&commentId=${commentId}&content=${encodeURIComponent(content)}`
            });
            const data = await res.json();
            if (data.success) {
                const display = document.getElementById('commentContent_' + commentId);
                const editBox = document.getElementById('editBox_' + commentId);
                display.querySelector('p').textContent = content;
                const editedSpan = display.querySelector('span[style*="italic"]');
                if (!editedSpan) {
                    const span = document.createElement('span');
                    span.className = 'text-muted small';
                    span.style.cssText = 'font-style:italic;';
                    span.innerHTML = '<i class="bi bi-pencil-square me-1"></i>Edited';
                    display.appendChild(span);
                }
                display.classList.remove('d-none');
                editBox.classList.add('d-none');
            }
        } catch(e) { console.error(e); }
    }

    // Like comment function
    async function toggleCommentLike(btn, commentId) {
        btn.disabled = true;
        const isLiked = btn.dataset.liked === 'true';
        
        try {
            const res = await fetch('@Url.Action("LikeComment", "Home")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `commentId=${commentId}`
            });
            const data = await res.json();
            if (data.success) {
                btn.dataset.liked = data.isLiked.toString();
                const icon = btn.querySelector('i');
                const countSpan = btn.querySelector('.like-count');
                if (data.isLiked) {
                    icon.className = 'bi bi-heart-fill';
                    btn.classList.add('text-danger');
                } else {
                    icon.className = 'bi bi-heart';
                    btn.classList.remove('text-danger');
                }
                countSpan.textContent = data.count;
            }
        } catch(e) { console.error(e); }
        btn.disabled = false;
    }

    // Sort comments
    function sortComments(sortBy) {
        const commentsList = document.getElementById('commentsList');
        const comments = Array.from(document.querySelectorAll('[data-comment-id]')).filter(el => {
            return el.closest('.ll-reader-below') && el.style.paddingBottom;
        });
        
        if (sortBy === 'recent') {
            comments.sort((a, b) => {
                const aId = parseInt(a.dataset.commentId);
                const bId = parseInt(b.dataset.commentId);
                return bId - aId;
            });
        } else if (sortBy === 'liked') {
            comments.sort((a, b) => {
                const aLikes = parseInt(a.querySelector('.like-count')?.textContent || '0');
                const bLikes = parseInt(b.querySelector('.like-count')?.textContent || '0');
                return bLikes - aLikes;
            });
        }

        // Update button states
        const recentBtn = document.getElementById('sortRecent');
        const likedBtn = document.getElementById('sortLiked');
        if (sortBy === 'recent') {
            recentBtn.style.background = '#fff';
            recentBtn.style.color = '#1e293b';
            recentBtn.style.borderColor = '#cbd5e1';
            likedBtn.style.background = '#fff';
            likedBtn.style.color = '#1e293b';
            likedBtn.style.borderColor = '#cbd5e1';
        } else if (sortBy === 'liked') {
            recentBtn.style.background = '#fff';
            recentBtn.style.color = '#1e293b';
            recentBtn.style.borderColor = '#cbd5e1';
            likedBtn.style.background = '#3b82f6';
            likedBtn.style.color = '#fff';
            likedBtn.style.borderColor = '#3b82f6';
        }
        
        // Re-append comments in new order
        comments.forEach(comment => {
            if (commentsList.contains(comment)) {
                commentsList.appendChild(comment);
            }
        });
    }

    // Hook up delete modal confirm button
    document.addEventListener('DOMContentLoaded', function() {
        const confirmBtn = document.getElementById('confirmDeleteBtn');
        if (confirmBtn) {
            confirmBtn.addEventListener('click', confirmDeleteComment);
        }
    });
</script>
}
