@{
    ViewData["Title"] = "Complete Profile - LearnLink";
    Layout = null;

    var googleEmail = ViewBag.GoogleEmail as string ?? "";
    var googleFirstName = ViewBag.GoogleFirstName as string ?? "";
    var googleLastName = ViewBag.GoogleLastName as string ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="icon" type="image/png" href="/images/LearnLink.png" />
    <link rel="stylesheet" href="~/css/learnlink.css" asp-append-version="true" />
</head>
<body class="ll-auth-body">
    <!-- Auth Header -->
    <nav class="ll-auth-header">
        <div class="container-fluid px-4">
            <div class="d-flex align-items-center justify-content-between">
                <div class="ll-auth-logo">
                    <img src="/images/Learnlink.png" alt="LearnLink" style="height: 64px; width: auto;" />
                    <span class="ll-auth-logo-text"><span class="fw-bold">Learn</span><span style="color: var(--ll-accent, #E8B84B);">Link</span></span>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <a href="@Url.Action("Index", "Home")" class="ll-auth-nav-link"><i class="bi bi-house-door me-1"></i>Home</a>
                    <div class="d-flex gap-2">
                        <a href="@Url.Action("Login", "Home")" class="btn btn-primary">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                        </a>
                        <a href="@Url.Action("Register", "Home")" class="btn fw-medium" style="background: var(--ll-accent, #E8B84B); color: #1e293b;">
                            <i class="bi bi-person-plus me-1"></i>Register
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Auth Content -->
    <div class="ll-auth-wrapper">
        <div class="container-fluid p-0">
            <div class="row g-0 justify-content-center">
                <div class="col-lg-6 ll-auth-right">
                    <div class="ll-auth-form-container">
                        <div class="ll-auth-form-card">
                            <div class="text-center mb-4">
                                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 56px; height: 56px; background: #d1fae5;">
                                    <i class="bi bi-google fs-4" style="color: #059669;"></i>
                                </div>
                                <h2 class="ll-auth-form-title">Complete your profile</h2>
                                <p class="ll-auth-form-subtitle mb-0">
                                    You signed in with Google as <strong>@googleEmail</strong>.<br />
                                    Please fill in the remaining details to finish registration.
                                </p>
                            </div>

                            <form asp-action="CompleteProfile" method="post">
                                @if (ViewBag.Error != null)
                                {
                                    <div class="alert alert-danger small py-2 mb-3">
                                        <i class="bi bi-exclamation-circle me-1"></i>@ViewBag.Error
                                    </div>
                                }

                                <input type="hidden" name="email" value="@googleEmail" />

                                <!-- Name Fields -->
                                <div class="row g-3 mb-3">
                                    <div class="col-md-4">
                                        <label class="form-label">First Name <span class="text-danger">*</span></label>
                                        <div class="ll-auth-input-group">
                                            <i class="bi bi-person ll-auth-input-icon"></i>
                                            <input type="text" name="firstName" class="form-control" placeholder="First name" value="@googleFirstName" required>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Middle Name</label>
                                        <div class="ll-auth-input-group">
                                            <i class="bi bi-person ll-auth-input-icon"></i>
                                            <input type="text" name="middleName" class="form-control" placeholder="Middle name (optional)">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Last Name <span class="text-danger">*</span></label>
                                        <div class="ll-auth-input-group">
                                            <i class="bi bi-person ll-auth-input-icon"></i>
                                            <input type="text" name="lastName" class="form-control" placeholder="Last name" value="@googleLastName" required>
                                        </div>
                                    </div>
                                </div>

                                <!-- Grade/Position -->
                                <div class="mb-3">
                                    <label class="form-label">Grade / Position</label>
                                    <div class="ll-auth-input-group">
                                        <i class="bi bi-bookmark ll-auth-input-icon"></i>
                                        <input type="text" name="gradeOrPosition" class="form-control" placeholder="e.g., Grade 8 - Section A or Math Teacher">
                                    </div>
                                </div>

                                <!-- Password -->
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Password <span class="text-danger">*</span></label>
                                        <div class="ll-auth-input-group">
                                            <i class="bi bi-lock ll-auth-input-icon"></i>
                                            <input type="password" name="password" id="regPassword" class="form-control" placeholder="Create password" required>
                                            <button type="button" class="ll-auth-password-toggle" onclick="togglePassword('regPassword', this)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        </div>
                                        <div class="form-text small text-muted">Min 6 characters</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Confirm Password <span class="text-danger">*</span></label>
                                        <div class="ll-auth-input-group">
                                            <i class="bi bi-lock-fill ll-auth-input-icon"></i>
                                            <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" placeholder="Re-enter password" required>
                                            <button type="button" class="ll-auth-password-toggle" onclick="togglePassword('confirmPassword', this)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <!-- School -->
                                <div class="mb-3">
                                    <label class="form-label">School <span class="text-danger">*</span></label>
                                    <div class="ll-auth-input-group">
                                        <i class="bi bi-building ll-auth-input-icon"></i>
                                        <select name="schoolId" class="form-control form-select" required>
                                            <option value="" disabled selected>Select your school</option>
                                            @if (ViewBag.Schools is List<LearnLink.Models.School> schools)
                                            {
                                                foreach (var school in schools)
                                                {
                                                    <option value="@school.SchoolId">@school.Name</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>

                                <button type="submit" class="btn ll-auth-btn-accent w-100 py-2 mb-3">
                                    <i class="bi bi-check-circle me-2"></i>Complete Registration
                                </button>

                                <div class="text-center">
                                    <span class="text-muted small">Want to use a different account?</span>
                                    <a href="@Url.Action("Register", "Home")" class="text-decoration-none small fw-semibold" style="color: var(--ll-primary);">Go back</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
</body>
</html>
