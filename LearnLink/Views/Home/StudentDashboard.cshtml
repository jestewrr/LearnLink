@model LearnLink.Models.StudentDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
    ViewData["ActivePage"] = "StudentDashboard";

    var phtNow = DateTime.UtcNow.AddHours(8);
    var greeting = phtNow.Hour < 12 ? "Good morning" : phtNow.Hour < 17 ? "Good afternoon" : "Good evening";
    var userName = User.Identity?.Name ?? "Student";
}

<!-- Page Header -->
<div class="ll-page-header">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="ll-page-title">@greeting! <span class="fw-normal opacity-75">Here's your learning overview</span></h1>
            <div class="ll-breadcrumb">
                <a href="#">Home</a>
                <i class="bi bi-chevron-right small"></i>
                <span>My Dashboard</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Repository", "Home")" class="ll-btn ll-btn-outline-primary">
                <i class="bi bi-folder2-open"></i>
                Browse Resources
            </a>
        </div>
    </div>
</div>

<!-- KPI Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-6 col-sm-6 col-xl-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon primary">
                <i class="bi bi-book"></i>
            </div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@Model.ResourcesRead</div>
                <div class="ll-stat-label">Resources Read</div>
                <div class="ll-stat-change positive">
                    <i class="bi bi-check-circle"></i>
                    @Model.ResourcesCompleted completed
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-6 col-xl-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon success">
                <i class="bi bi-trophy"></i>
            </div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@Model.CompletionPercent%</div>
                <div class="ll-stat-label">Completion Rate</div>
                <div class="ll-stat-change positive">
                    <i class="bi bi-fire"></i>
                    @Model.CurrentStreak day streak
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-6 col-xl-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon warning">
                <i class="bi bi-lightbulb"></i>
            </div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@Model.LessonsSubmitted</div>
                <div class="ll-stat-label">Lessons Submitted</div>
                <div class="ll-stat-change positive">
                    <i class="bi bi-bookmark"></i>
                    @Model.Bookmarks bookmarked
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-6 col-xl-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon info">
                <i class="bi bi-chat-dots"></i>
            </div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@Model.DiscussionsParticipated</div>
                <div class="ll-stat-label">Discussions Joined</div>
                <div class="ll-stat-change positive">
                    <i class="bi bi-star"></i>
                    Best: @Model.BestStreak day streak
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Active Learning + Gamification -->
<div class="row g-4 mb-4">
    <!-- Continue Reading (Wide) -->
    <div class="col-lg-8">
        <div class="ll-card h-100 border-0 shadow-sm" style="border-radius: 16px;">
            <div class="ll-card-header d-flex justify-content-between align-items-center bg-white border-bottom-0 pb-0 pt-4 px-4">
                <h5 class="ll-card-title fw-bold mb-0" style="color: #1e293b;"><i class="bi bi-clock-history me-2" style="color: var(--ll-primary);"></i>Continue Reading</h5>
                <a href="@Url.Action("ReadingHistory", "Home")" class="ll-btn ll-btn-outline-primary btn-sm rounded-pill px-3">View All</a>
            </div>
            <div class="ll-card-body p-4">
                @if (Model.RecentReading.Any())
                {
                <div class="row g-3">
                    @foreach (var item in Model.RecentReading.Take(4))
                    {
                    <div class="col-md-6">
                        <a href="@Url.Action("ResourceDetail", "Home", new { id = item.ResourceId })" class="text-decoration-none d-block">
                            <div class="p-3 rounded-4 transition-all hover-scale" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                                <div class="d-flex align-items-center gap-3 mb-2">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width:48px;height:48px;background:@item.IconBg;min-width:48px;">
                                        <i class="bi @item.IconClass @item.IconColor fs-5"></i>
                                    </div>
                                    <div class="flex-grow-1 min-w-0">
                                        <div class="fw-bold text-truncate" style="color: #0f172a; font-size: 1.05rem;" title="@item.Title">@item.Title</div>
                                        <div class="small fw-medium" style="color: #64748b;">@item.Subject</div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center justify-content-between mb-1 mt-3">
                                    <span class="small fw-bold" style="color: #334155;">Progress</span>
                                    <span class="small fw-bold @(item.IsCompleted ? "text-success" : "text-primary")">@item.ProgressPercent%</span>
                                </div>
                                <div class="progress rounded-pill bg-white shadow-sm" style="height: 6px; border: 1px solid #e2e8f0;">
                                    <div class="progress-bar rounded-pill @(item.IsCompleted ? "bg-success" : "bg-primary")" style="width: @item.ProgressPercent%"></div>
                                </div>
                            </div>
                        </a>
                    </div>
                    }
                </div>
                }
                else
                {
                <div class="text-center py-5 text-muted border border-dashed rounded-4 bg-light">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3 bg-white shadow-sm" style="width: 64px; height: 64px;">
                        <i class="bi bi-book display-6 text-primary"></i>
                    </div>
                    <h5 class="fw-bold text-dark">No active reading</h5>
                    <p class="mb-3">Start exploring topics to build your Continue Reading list!</p>
                    <a href="@Url.Action("Repository", "Home")" class="ll-btn ll-btn-primary rounded-pill px-4">Browse Now</a>
                </div>
                }
            </div>
        </div>
    </div>

    <!-- Gamification Stack (Narrow) -->
    <div class="col-lg-4 d-flex flex-column gap-4">
        <!-- Learning Streak -->
        <div class="ll-card border-0 shadow-sm flex-fill" style="background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%); border-radius: 16px;">
            <div class="ll-card-header bg-transparent border-bottom-0 pb-0 pt-4 px-4 text-center">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white shadow-sm mb-2" style="width: 50px; height: 50px;">
                    <i class="bi bi-fire fs-4" style="color: #f59e0b;"></i>
                </div>
                <h5 class="ll-card-title fw-bold mb-0" style="color: #92400e;">Learning Streak</h5>
            </div>
            <div class="ll-card-body text-center py-3 px-4">
                <div class="d-flex justify-content-center gap-4 align-items-end mb-3">
                    <div>
                        <div class="fw-black lh-1" style="font-size: 3.5rem; color: #b45309; letter-spacing: -2px;">@Model.CurrentStreak</div>
                        <div class="fw-bold text-uppercase" style="font-size: 0.75rem; color: #d97706; letter-spacing: 1px;">Current Days</div>
                    </div>
                    <div style="width: 2px; height: 40px; background: rgba(217,119,6,0.2);" class="mb-2"></div>
                    <div>
                        <div class="fw-black lh-1" style="font-size: 2.5rem; color: #d97706; letter-spacing: -1px;">@Model.BestStreak</div>
                        <div class="fw-bold text-uppercase" style="font-size: 0.75rem; color: #f59e0b; letter-spacing: 1px;">Best Days</div>
                    </div>
                </div>
                <div class="progress rounded-pill bg-white shadow-sm" style="height: 8px;">
                    @{
                        var streakPercent = Model.BestStreak > 0 ? Math.Min(100, (int)Math.Round((double)Model.CurrentStreak / Model.BestStreak * 100)) : 0;
                    }
                    <div class="progress-bar rounded-pill" style="width: @streakPercent%; background: linear-gradient(90deg, #f59e0b 0%, #d97706 100%);"></div>
                </div>
                <div class="small fw-bold mt-2" style="color: #b45309;">@streakPercent% of your best streak</div>
            </div>
        </div>

        <!-- Weekly Target -->
        <div class="ll-card border-0 shadow-sm" style="border-radius: 16px;">
            <div class="ll-card-header d-flex justify-content-between align-items-center bg-white border-bottom-0 pb-0 pt-4 px-4">
                <h6 class="ll-card-title fw-bold mb-0" style="color: #1e293b;"><i class="bi bi-bullseye me-2 text-info"></i>Weekly Target</h6>
                <span class="badge bg-primary bg-opacity-10 text-primary fw-bold rounded-pill px-3 py-2">@Model.WeeklyResourcesCompleted / @Model.WeeklyResourceGoal</span>
            </div>
            <div class="ll-card-body pb-4 pt-3 px-4">
                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-medium small" style="color: #64748b;">Resources Read</span>
                    <span class="fw-bold small @(Model.WeeklyResourcesCompleted >= Model.WeeklyResourceGoal ? "text-success" : "text-dark")">
                        @(Model.WeeklyResourcesCompleted >= Model.WeeklyResourceGoal ? "Goal Reached! 🎉" : $"{Model.WeeklyResourceGoal - Model.WeeklyResourcesCompleted} left")
                    </span>
                </div>
                <div class="progress rounded-pill bg-light" style="height: 10px; border: 1px solid #e2e8f0;">
                    @{
                        var weeklyGoalPercent = Model.WeeklyResourceGoal > 0 ? Math.Min(100, (int)Math.Round((double)Model.WeeklyResourcesCompleted / Model.WeeklyResourceGoal * 100)) : 0;
                    }
                    <div class="progress-bar rounded-pill @(weeklyGoalPercent >= 100 ? "bg-success" : "bg-primary") progress-bar-striped @(weeklyGoalPercent >= 100 ? "" : "progress-bar-animated")" style="width: @weeklyGoalPercent%"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Discovery & Bookmarks -->
<div class="row g-4 mb-4">
    <!-- Recommended Resources -->
    <div class="col-lg-6">
        <div class="ll-card h-100 border-0 shadow-sm" style="border-radius: 16px;">
            <div class="ll-card-header d-flex justify-content-between align-items-center bg-white border-bottom-0 pb-0 pt-4 px-4">
                <h5 class="ll-card-title fw-bold mb-0" style="color: #1e293b;"><i class="bi bi-stars me-2 text-warning"></i>Recommended</h5>
                <a href="@Url.Action("Repository", "Home")" class="ll-btn ll-btn-outline-primary btn-sm rounded-pill px-3">All Resources</a>
            </div>
            <div class="ll-card-body px-4 pt-3 pb-4">
                @if (Model.RecommendedResources.Any())
                {
                <div class="list-group list-group-flush gap-2">
                    @foreach (var res in Model.RecommendedResources.Take(4))
                    {
                    <a href="@Url.Action("ResourceDetail", "Home", new { id = res.Id })" class="list-group-item list-group-item-action border border-light rounded-3 px-3 py-3 shadow-sm transition-all hover-scale" style="background: #fff;">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width:42px;height:42px;background:@res.IconBg;min-width:42px;">
                                <i class="bi @res.IconClass @res.IconColor fs-6"></i>
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-bold text-truncate text-dark" style="font-size: 0.95rem;" title="@res.Title">@res.Title</div>
                                <div class="small fw-medium" style="color: #64748b;">@res.Subject</div>
                            </div>
                            <span class="badge bg-light text-dark border rounded-pill px-2 py-1 fw-medium" style="font-size: 0.7rem;">@res.ResourceType</span>
                        </div>
                    </a>
                    }
                </div>
                }
                else
                {
                <div class="text-center py-5 text-muted border border-dashed rounded-4 bg-light h-100 d-flex flex-column justify-content-center">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white shadow-sm mb-3 mx-auto" style="width: 56px; height: 56px;">
                        <i class="bi bi-check-all fs-3 text-warning"></i>
                    </div>
                    <h6 class="fw-bold text-dark">You're all caught up!</h6>
                    <p class="small mb-0">Check back later for more recommendations.</p>
                </div>
                }
            </div>
        </div>
    </div>

    <!-- Quick Access Bookmarks -->
    <div class="col-lg-6">
        <div class="ll-card h-100 border-0 shadow-sm" style="border-radius: 16px;">
            <div class="ll-card-header d-flex justify-content-between align-items-center bg-white border-bottom-0 pb-0 pt-4 px-4">
                <h5 class="ll-card-title fw-bold mb-0" style="color: #1e293b;"><i class="bi bi-bookmark-fill me-2 text-primary"></i>Bookmarks</h5>
                <a href="@Url.Action("ReadingHistory", "Home", new { filter = "bookmarked" })" class="ll-btn ll-btn-outline-primary btn-sm rounded-pill px-3">View Saved</a>
            </div>
            <div class="ll-card-body px-4 pt-3 pb-4">
                @if (Model.RecentBookmarks.Any())
                {
                <div class="list-group list-group-flush gap-2">
                    @foreach (var res in Model.RecentBookmarks.Take(4))
                    {
                    <a href="@Url.Action("ResourceDetail", "Home", new { id = res.Id })" class="list-group-item list-group-item-action border border-light rounded-3 px-3 py-3 shadow-sm transition-all hover-scale" style="background: #fff;">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width:42px;height:42px;background:@res.IconBg;min-width:42px;">
                                <i class="bi @res.IconClass @res.IconColor fs-6"></i>
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-bold text-truncate text-dark" style="font-size: 0.95rem;" title="@res.Title">@res.Title</div>
                                <div class="small fw-medium" style="color: #64748b;">@res.Subject &middot; @res.Uploader</div>
                            </div>
                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                                <i class="bi bi-chevron-right text-primary small"></i>
                            </div>
                        </div>
                    </a>
                    }
                </div>
                }
                else
                {
                <div class="text-center py-5 text-muted border border-dashed rounded-4 bg-light h-100 d-flex flex-column justify-content-center">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white shadow-sm mb-3 mx-auto" style="width: 56px; height: 56px;">
                        <i class="bi bi-bookmark fs-3 text-primary"></i>
                    </div>
                    <h6 class="fw-bold text-dark">No bookmarks yet</h6>
                    <p class="small mb-0">Save resources you want to read later.</p>
                </div>
                }
            </div>
        </div>
    </div>
</div>
<style>
    .transition-all {
        transition: all 0.2s ease-in-out;
    }
    .hover-scale:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
        border-color: #cbd5e1 !important;
    }
</style>

@section Scripts {
}
