@{
    ViewData["Title"] = "Announcements";
    ViewData["ActivePage"] = "Announcements";

    var canManage = ViewBag.CanManage == true;
    var announcements = ViewBag.Announcements as List<LearnLink.Models.AnnouncementViewModel> ?? new List<LearnLink.Models.AnnouncementViewModel>();
    var pinnedCount = announcements.Count(a => a.IsPinned);
}

<!-- Page Header -->
<div class="ll-page-header">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="ll-page-title">Announcements</h1>
            <div class="ll-breadcrumb">
                <a href="#">Home</a>
                <i class="bi bi-chevron-right small"></i>
                <span>Announcements</span>
            </div>
        </div>
        @if (canManage)
        {
        <div class="d-flex gap-2">
            <button class="ll-btn ll-btn-primary" data-bs-toggle="modal" data-bs-target="#newAnnouncementModal">
                <i class="bi bi-megaphone"></i>
                New Announcement
            </button>
        </div>
        }
    </div>
</div>

<!-- Stats Row -->
<div class="row g-4 mb-4">
    <div class="col-6 col-md-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon primary"><i class="bi bi-megaphone"></i></div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@announcements.Count</div>
                <div class="ll-stat-label">Total</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon warning"><i class="bi bi-pin-angle"></i></div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@pinnedCount</div>
                <div class="ll-stat-label">Pinned</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon danger"><i class="bi bi-exclamation-triangle"></i></div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@announcements.Count(a => a.Priority == "Urgent")</div>
                <div class="ll-stat-label">Urgent</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ll-stat-card">
            <div class="ll-stat-icon success"><i class="bi bi-clock"></i></div>
            <div class="ll-stat-content">
                <div class="ll-stat-value">@announcements.Count(a => a.ExpiresAt.HasValue && a.ExpiresAt > DateTime.Now)</div>
                <div class="ll-stat-label">Active Expiry</div>
            </div>
        </div>
    </div>
</div>

<!-- Announcements Feed -->
<div class="row g-4">
    <div class="col-12">
        @if (!announcements.Any())
        {
        <div class="ll-card">
            <div class="ll-card-body text-center py-5">
                <i class="bi bi-megaphone display-3 text-muted d-block mb-3"></i>
                <h5 class="text-muted">No Announcements Yet</h5>
                <p class="text-muted mb-0">
                    @if (canManage)
                    {
                        <span>Create the first announcement to keep everyone informed.</span>
                    }
                    else
                    {
                        <span>Check back later for updates from your school.</span>
                    }
                </p>
            </div>
        </div>
        }
        else
        {
            @foreach (var ann in announcements)
            {
            <div class="ll-card mb-3 @(ann.IsPinned ? "border-start border-4 border-primary" : "") @(ann.ExpiresAt.HasValue && ann.ExpiresAt < DateTime.Now ? "opacity-50" : "")">
                <div class="ll-card-body">
                    <div class="d-flex align-items-start gap-3">
                        <!-- Priority indicator -->
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:44px;height:44px;background:@(ann.Priority == "Urgent" ? "#fee2e2" : ann.Priority == "Important" ? "#fef3c7" : "#dbeafe")">
                            <i class="bi @ann.PriorityIcon @(ann.Priority == "Urgent" ? "text-danger" : ann.Priority == "Important" ? "text-warning" : "text-primary")"></i>
                        </div>

                        <div class="flex-grow-1 min-w-0">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-1">
                                <div>
                                    <h6 class="mb-0 fw-semibold">
                                        @if (ann.IsPinned) { <i class="bi bi-pin-fill text-primary me-1" title="Pinned"></i> }
                                        @ann.Title
                                    </h6>
                                    <small class="text-muted">
                                        <span class="fw-medium">@ann.Author</span> &middot; @ann.DateCreated.ToString("MMM dd, yyyy h:mm tt")
                                        @if (ann.ExpiresAt.HasValue)
                                        {
                                            <span>&middot; Expires: @ann.ExpiresAt.Value.ToString("MMM dd, yyyy")</span>
                                        }
                                    </small>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge @ann.PriorityBadgeClass">@ann.Priority</span>
                                    @if (ann.ExpiresAt.HasValue && ann.ExpiresAt < DateTime.Now)
                                    {
                                        <span class="badge ll-badge-secondary">Expired</span>
                                    }
                                    @if (canManage)
                                    {
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border-0" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#editAnnouncementModal"
                                                        onclick="fillEditForm(@ann.Id, '@System.Net.WebUtility.HtmlEncode(ann.Title)', `@System.Net.WebUtility.HtmlEncode(ann.Content)`, '@ann.Priority', @ann.IsPinned.ToString().ToLower(), '@(ann.ExpiresAt?.ToString("yyyy-MM-dd") ?? "")')">
                                                    <i class="bi bi-pencil me-2"></i>Edit
                                                </button>
                                            </li>
                                            <li>
                                                <form asp-action="TogglePinAnnouncement" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@ann.Id" />
                                                    <button type="submit" class="dropdown-item">
                                                        <i class="bi @(ann.IsPinned ? "bi-pin-angle" : "bi-pin-fill") me-2"></i>
                                                        @(ann.IsPinned ? "Unpin" : "Pin")
                                                    </button>
                                                </form>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form asp-action="DeleteAnnouncement" method="post" class="d-inline"
                                                      onsubmit="return confirm('Delete this announcement?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@ann.Id" />
                                                    <button type="submit" class="dropdown-item text-danger">
                                                        <i class="bi bi-trash me-2"></i>Delete
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                    }
                                </div>
                            </div>
                            <p class="mb-0 mt-2" style="white-space: pre-line;">@ann.Content</p>
                        </div>
                    </div>
                </div>
            </div>
            }
        }
    </div>
</div>

@if (canManage)
{
<!-- New Announcement Modal -->
<div class="modal fade" id="newAnnouncementModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="PostAnnouncement" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-megaphone me-2 text-primary"></i>New Announcement</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Title <span class="text-danger">*</span></label>
                        <input type="text" name="title" class="form-control" maxlength="200" required placeholder="Announcement title..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Content <span class="text-danger">*</span></label>
                        <textarea name="content" class="form-control" rows="5" required placeholder="Write your announcement..."></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Priority</label>
                            <select name="priority" class="form-select">
                                <option value="Normal" selected>Normal</option>
                                <option value="Important">Important</option>
                                <option value="Urgent">Urgent</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Expires On</label>
                            <input type="date" name="expiresAt" class="form-control" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" name="isPinned" value="true" id="newPinned" />
                                <label class="form-check-label" for="newPinned">Pin to top</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="ll-btn ll-btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="ll-btn ll-btn-primary"><i class="bi bi-send me-1"></i>Post Announcement</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Announcement Modal -->
<div class="modal fade" id="editAnnouncementModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="EditAnnouncement" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editAnnId" />
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-pencil me-2 text-primary"></i>Edit Announcement</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Title <span class="text-danger">*</span></label>
                        <input type="text" name="title" id="editAnnTitle" class="form-control" maxlength="200" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Content <span class="text-danger">*</span></label>
                        <textarea name="content" id="editAnnContent" class="form-control" rows="5" required></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Priority</label>
                            <select name="priority" id="editAnnPriority" class="form-select">
                                <option value="Normal">Normal</option>
                                <option value="Important">Important</option>
                                <option value="Urgent">Urgent</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Expires On</label>
                            <input type="date" name="expiresAt" id="editAnnExpires" class="form-control" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" name="isPinned" value="true" id="editAnnPinned" />
                                <label class="form-check-label" for="editAnnPinned">Pin to top</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="ll-btn ll-btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="ll-btn ll-btn-primary"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
}

@section Scripts {
<script>
function fillEditForm(id, title, content, priority, isPinned, expiresAt) {
    document.getElementById('editAnnId').value = id;
    document.getElementById('editAnnTitle').value = title;
    document.getElementById('editAnnContent').value = content;
    document.getElementById('editAnnPriority').value = priority;
    document.getElementById('editAnnPinned').checked = isPinned;
    document.getElementById('editAnnExpires').value = expiresAt;
}
</script>
}
