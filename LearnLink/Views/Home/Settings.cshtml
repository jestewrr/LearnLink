@using System.Text.Json
@{
    ViewData["Title"] = "School Settings";
    ViewData["ActivePage"] = "Settings";

    var settings = ViewBag.SchoolSettingsModel as LearnLink.Models.SchoolSettings;
    var institutionName = settings?.InstitutionName ?? "LearnLink";
    var adminEmail = settings?.AdminEmail ?? "";

    // Parse JSON arrays back to comma-separated strings for the form
    var subjectsList = ViewBag.SchoolSubjects as List<string> ?? new List<string>();
    var gradesList = ViewBag.SchoolGradeLevels as List<string> ?? new List<string>();
    var typesList = ViewBag.SchoolResourceTypes as List<string> ?? new List<string>();
    var quartersList = ViewBag.SchoolQuarters as List<string> ?? new List<string>();

    var subjectsStr = string.Join(", ", subjectsList);
    var gradesStr = string.Join(", ", gradesList);
    var typesStr = string.Join(", ", typesList);
    var quartersStr = string.Join(", ", quartersList);
}

<!-- Page Header -->
<div class="ll-page-header">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="ll-page-title">School Settings</h1>
            <div class="ll-breadcrumb">
                <a href="@Url.Action("Dashboard", "Home")">Dashboard</a>
                <i class="bi bi-chevron-right small"></i>
                <span>Settings</span>
            </div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
<div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}
@if (TempData["ErrorMessage"] != null)
{
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}
@if (TempData["WarningMessage"] != null)
{
<div class="alert alert-warning alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["WarningMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}

<form asp-action="SaveSettings" method="post">
<div class="row g-4">
    <div class="col-12">
        <!-- General Settings -->
        <div class="ll-card mb-4" id="general">
            <div class="ll-card-header">
                <h5 class="ll-card-title"><i class="bi bi-gear me-2"></i>General Settings</h5>
            </div>
            <div class="ll-card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="ll-form-group">
                            <label class="ll-form-label">Institution Name</label>
                            <input type="text" name="institutionName" class="ll-form-control" value="@institutionName">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="ll-form-group">
                            <label class="ll-form-label">Admin Email</label>
                            <input type="email" name="adminEmail" class="ll-form-control" value="@adminEmail">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Academic Configuration -->
        <div class="ll-card mb-4" id="academic">
            <div class="ll-card-header">
                <h5 class="ll-card-title"><i class="bi bi-book me-2"></i>Academic Configuration</h5>
                <p class="text-muted small mb-0">Define the subjects, grade levels, resource types, and quarters available in this school. These values populate dropdowns across the system.</p>
            </div>
            <div class="ll-card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="ll-form-group">
                            <label class="ll-form-label">Subjects</label>
                            <textarea name="subjects" class="ll-form-control" rows="3" placeholder="Mathematics, Science, English, Filipino, Araling Panlipunan, MAPEH, TLE, Values Education">@subjectsStr</textarea>
                            <div class="form-text small">Comma-separated list of subjects.</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="ll-form-group">
                            <label class="ll-form-label">Grade Levels</label>
                            <textarea name="gradeLevels" class="ll-form-control" rows="3" placeholder="Grade 7, Grade 8, Grade 9, Grade 10, All Grades">@gradesStr</textarea>
                            <div class="form-text small">Comma-separated list of grade levels.</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="ll-form-group">
                            <label class="ll-form-label">Resource Types</label>
                            <textarea name="resourceTypes" class="ll-form-control" rows="3" placeholder="Reviewer / Study Guide, Lesson Plan, Activity Sheet, Assessment / Quiz, Presentation, Video Tutorial, Reading Material, Reference Document">@typesStr</textarea>
                            <div class="form-text small">Comma-separated list of allowed resource types.</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="ll-form-group">
                            <label class="ll-form-label">Quarters</label>
                            <textarea name="quarters" class="ll-form-control" rows="3" placeholder="1st Quarter, 2nd Quarter, 3rd Quarter, 4th Quarter, All Quarters">@quartersStr</textarea>
                            <div class="form-text small">Comma-separated list of academic quarters.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Save Button -->
        <div class="d-flex gap-2 justify-content-end">
            <a href="@Url.Action("Dashboard", "Home")" class="ll-btn ll-btn-outline">Cancel</a>
            <button type="submit" class="ll-btn ll-btn-primary">
                <i class="bi bi-check-lg"></i>
                Save All Changes
            </button>
        </div>
    </div>
</div>
</form>

@if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
{
<!-- Import Google Books (separate from the settings form) -->
<div class="ll-card mb-4 mt-4" id="importBooks" style="background: linear-gradient(135deg, #f8f9fa, #ffffff); border-left: 4px solid #4285F4;">
    <div class="ll-card-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 border-0 pb-0">
        <h5 class="ll-card-title mb-0"><i class="bi bi-book me-2" style="color: #4285F4;"></i>Import Books</h5>
        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">Google Books + Open Library</span>
    </div>
    <div class="ll-card-body pt-3">
        <p class="text-muted small mb-3">Quickly fetch and add up to 10 free educational books per request. Uses Google Books API when available, with automatic fallback to Open Library. Imported books will appear in the Knowledge Repository.</p>
        <form action="@Url.Action("ImportGoogleBooks", "Home")" method="post" class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="ll-form-label small">Subject</label>
                <select name="subject" class="ll-form-control ll-form-select" required>
                    <option value="" disabled selected>Select Subject...</option>
                    @foreach (var subj in subjectsList)
                    {
                        <option value="@subj">@subj</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="ll-form-label small">Grade Level</label>
                <select name="grade" class="ll-form-control ll-form-select" required>
                    <option value="" disabled selected>Select Grade...</option>
                    @foreach (var grade in gradesList)
                    {
                        <option value="@grade">@grade</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-4">
                <button type="submit" class="ll-btn ll-btn-primary w-100" id="fetchBooksBtn">
                    <i class="bi bi-cloud-download me-1"></i> Fetch Books
                </button>
            </div>
        </form>
    </div>
</div>
<script>
    document.querySelector('form[action*="ImportGoogleBooks"]')?.addEventListener('submit', function() {
        var btn = document.getElementById('fetchBooksBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Fetching from Google Books...';
    });
</script>
}
