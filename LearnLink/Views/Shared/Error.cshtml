@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Error.</h1>
<h2 class="text-danger">An error occurred while processing your request.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

@if (User.IsInRole("SuperAdmin") && !string.IsNullOrEmpty(Model.ExceptionMessage))
{
    <div class="alert alert-danger mt-4">
        <h4 class="alert-heading"><i class="bi bi-bug-fill me-2"></i>Exception Details (visible to admins only)</h4>
        <hr />
        <p><strong>Message:</strong> @Model.ExceptionMessage</p>
        @if (!string.IsNullOrEmpty(Model.ExceptionDetails))
        {
            <details>
                <summary class="fw-bold" style="cursor:pointer;">Full Stack Trace</summary>
                <pre class="mt-2 p-3 bg-dark text-light rounded" style="white-space:pre-wrap;word-break:break-word;max-height:500px;overflow-y:auto;font-size:0.85rem;">@Model.ExceptionDetails</pre>
            </details>
        }
    </div>
}
else
{
    <p class="text-muted mt-3">If this problem persists, please contact the system administrator.</p>
}
